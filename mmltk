prepare_container_invocation() {
    if (( gui_mode && !prepare_gui_container_mode )) && [[ ! -f "${gui_build_dist_dir}/index.html" ]]; then
        die "GUI bundle is missing. Build it with ./mmltk --build or ./mmltk --build-gui"
    fi

    container_cleanup_armed=1
    ensure_container
    terminate_existing_gui_instances
    build_exec_env_args

    container_workdir="/host${host_workdir}"
    settings_container_path="$(rewrite_host_path "${settings_host_path}")"

    exec_args=(exec -i)
    interactive_tty=0
    if [[ -t 0 && -t 1 ]]; then
        exec_args+=(-t)
        interactive_tty=1
    fi
    exec_args+=("${exec_env_args[@]}" -w "${container_workdir}" "${container_name}")

    if (( gui_mode )); then
        container_command=(/opt/mmltk/bin/mmltk-browser-host --settings-path "${settings_container_path}")
        log "using packaged GUI bundle from ${gui_build_dist_dir}"
        if ((${#rewritten_args[@]} > 0)); then
            container_command+=(--seed-from-cli -- "${rewritten_args[@]}")
        fi
    else
        container_command=(/opt/mmltk/bin/mmltk "${rewritten_args[@]}")
    fi

    # When the caller redirects stdout/stderr (e.g. `./mmltk --gui 2>&1 | tee
    # log`), docker attaches the child process to pipes instead of a pty. glibc
    # then block-buffers stderr — on a crash the last diagnostics may disappear.
    # Line-buffer with stdbuf so
    # every newline flushes. Skip when already on a TTY since a terminal is
    # line-buffered natively and stdbuf would be a no-op wrapper.
    if (( ! interactive_tty )); then
        container_command=(stdbuf -oL -eL "${container_command[@]}")
    fi
}

run_prepared_container_invocation() {
    docker "${exec_args[@]}" "${container_command[@]}" <&0 &
    active_docker_pid=$!
    local exit_status=0
    if wait "${active_docker_pid}"; then
        exit_status=0
    else
        exit_status=$?
    fi
    active_docker_pid=0
    return "${exit_status}"
}

gui_mode=0
build_mode=0
build_gui_mode=0
tidy_mode=0
prepare_gui_container_mode=0
test_mode=0
test_suite=""
test_args=()
passthrough_args=()
for arg in "$@"; do
    if [[ "${arg}" == "--gui" ]]; then
        gui_mode=1
        continue
    fi
    if [[ "${arg}" == "--build" ]]; then
        build_mode=1
        continue
    fi
    if [[ "${arg}" == "--build-gui" ]]; then
        build_gui_mode=1
        continue
    fi
    if [[ "${arg}" == "--prepare-gui-container" ]]; then
        gui_mode=1
        prepare_gui_container_mode=1
        continue
    fi
    if [[ "${arg}" == "--tidy" ]]; then
        tidy_mode=1
        continue
    fi
    passthrough_args+=("${arg}")
done

if ((${#passthrough_args[@]} > 0)); then
    if [[ "${passthrough_args[0]}" == "--test" ]]; then
        test_mode=1
        ((${#passthrough_args[@]} >= 2)) || die "--test requires a suite name; use './mmltk --test list'"
        test_suite="${passthrough_args[1]}"
        test_args=("${passthrough_args[@]:2}")
    elif [[ "${passthrough_args[0]}" == --test=* ]]; then
        test_mode=1
        test_suite="${passthrough_args[0]#--test=}"
        [[ -n "${test_suite}" ]] || die "--test requires a suite name; use './mmltk --test list'"
        test_args=("${passthrough_args[@]:1}")
    fi
fi
if ((${#test_args[@]} > 0)) && [[ "${test_args[0]}" == "--" ]]; then
    test_args=("${test_args[@]:1}")
fi

if (( build_mode + build_gui_mode + tidy_mode + test_mode > 1 ||
      (build_mode || tidy_mode || test_mode) && gui_mode )); then
    die "--build, --test, and --tidy are standalone; --build-gui cannot be combined with them"
fi

if (( test_mode )); then
    run_tests "${test_suite}" "${test_args[@]}"
    exit $?
fi

rewrite_passthrough_args

if (( tidy_mode )); then
    run_tidy
    exit $?
fi

if (( build_mode )); then
    if ((${#passthrough_args[@]} > 0)); then
        die "--build does not accept application arguments"
    fi
    run_build
    exit $?
fi

if (( build_gui_mode )); then
    if (( ! gui_mode && ${#passthrough_args[@]} > 0 )); then
        die "--build-gui without --gui does not accept application arguments"
    fi
    run_gui_build
    if (( ! gui_mode )); then
        exit 0
    fi
fi

prepare_container_invocation

if (( prepare_gui_container_mode )); then
    exit 0
fi

run_prepared_container_invocation
