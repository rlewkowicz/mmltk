firefox_source_state_fingerprint() {
    local toolchain_identity="$1"
    {
        printf 'mmltk-firefox-build-input-v1\0%s\0' "${toolchain_identity}"
        sha256sum -- "${repo_root}/cmake/mmltk_firefox.cmake"
        git -C "${repo_root}" rev-parse HEAD:third_party/firefox
        git -C "${repo_root}" diff --no-ext-diff --binary \
            HEAD -- third_party/firefox
        local untracked_path
        while IFS= read -r -d '' untracked_path; do
            printf 'untracked\0%s\0%s\0' "${untracked_path}" \
                "$(fingerprint_path "${repo_root}/${untracked_path}")"
        done < <(git -C "${repo_root}" ls-files --others \
            --exclude-standard -z -- third_party/firefox)
    } | sha256sum | cut -d' ' -f1
}

firefox_runtime_cache_complete() {
    local runtime_root="${firefox_cache_root}/obj-minimal-opt/dist/firefox"
    local required_path
    for required_path in \
        firefox \
        firefox-bin \
        libxul.so \
        libmozgtk.so \
        libmozwayland.so \
        application.ini \
        platform.ini \
        omni.ja \
        browser/omni.ja; do
        [[ -e "${runtime_root}/${required_path}" ]] || return 1
    done
}

prepare_firefox_build_input() {
    local toolchain_identity
    toolchain_identity="$(docker image inspect "${build_image_name}" --format '{{.Id}}')"
    local fingerprint
    fingerprint="$(firefox_source_state_fingerprint "${toolchain_identity}")"
    local next_fingerprint="${firefox_build_input_file}.next.$$"
    printf '%s\n' "${fingerprint}" >"${next_fingerprint}"
    if [[ -f "${firefox_build_input_file}" ]] \
        && cmp -s -- "${next_fingerprint}" "${firefox_build_input_file}"; then
        rm -f -- "${next_fingerprint}"
    else
        mv -f -- "${next_fingerprint}" "${firefox_build_input_file}"
        chown "${uid}:${gid}" "${firefox_build_input_file}" 2>/dev/null || true
        log "Firefox build inputs changed"
    fi

    local legacy_runtime_stamp=
    legacy_runtime_stamp="${firefox_cache_root}/obj-minimal-opt/dist/.mmltk-runtime-stage.sha256"
    if [[ ! -f "${firefox_built_input_file}" \
        && -f "${legacy_runtime_stamp}" ]] \
        && firefox_runtime_cache_complete; then
        local newer_source
        newer_source="$(find "${repo_root}/third_party/firefox" -type f \
            -newer "${legacy_runtime_stamp}" -print -quit)"
        if [[ -z "${newer_source}" ]]; then
            cp -- "${firefox_build_input_file}" "${firefox_built_input_file}"
            chown "${uid}:${gid}" "${firefox_built_input_file}" 2>/dev/null || true
            log "adopted the completed Firefox runtime into fingerprinted build state"
        fi
    fi
}

run_release_ninja() {
    log "building the unified Release Ninja graph with ${build_jobs} workers on CPUs ${build_cpu_list}"
    run_toolchain_command \
        'set -euo pipefail
         capture_compiler_cache_stats() {
             if [[ -n "${MMLTK_CCACHE_STATS_FILE:-}" ]]; then
                 ccache --show-stats >"${MMLTK_CCACHE_STATS_FILE}" 2>&1 || true
             fi
             if [[ -n "${MMLTK_FIREFOX_SCCACHE_STATS_FILE:-}" ]]; then
                 sccache_bin="${MOZBUILD_STATE_PATH}/sccache/sccache"
                 if [[ -x "${sccache_bin}" ]]; then
                     "${sccache_bin}" --show-stats \
                         >"${MMLTK_FIREFOX_SCCACHE_STATS_FILE}" 2>&1 || true
                 fi
             fi
         }
         trap capture_compiler_cache_stats EXIT
         if [[ -n "${MMLTK_CCACHE_STATS_FILE:-}" ]]; then
             ccache --zero-stats
         fi
         sccache_bin="${MOZBUILD_STATE_PATH}/sccache/sccache"
         if [[ -x "${sccache_bin}" && -n "${MMLTK_FIREFOX_SCCACHE_STATS_FILE:-}" ]]; then
             "${sccache_bin}" --zero-stats || true
         fi
         /workspace/utilities/run_traced_command.sh cargo_fetch \
             cargo fetch --locked \
