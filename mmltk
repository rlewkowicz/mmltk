run_tests() {
    local suite="$1"
    shift

    if [[ "${suite}" == "list" || "${suite}" == "help" || "${suite}" == "-h" || "${suite}" == "--help" ]]; then
        (($# == 0)) || die "--test ${suite} does not accept additional arguments"
        print_test_suites
        return 0
    fi

    local -a targets=()
    local -a executables=()
    case "${suite}" in
        core)
            targets=(mmltk_tests_core)
            executables=(mmltk_tests_core)
            ;;
        gui)
            targets=(mmltk_tests_gui mmltk_browser_app_check)
            executables=(mmltk_tests_gui)
            ;;
        rfdetr)
            targets=(mmltk_tests_model_rfdetr)
            executables=(mmltk_tests_model_rfdetr)
            ;;
        all)
            targets=(
                mmltk_tests_core
                mmltk_tests_gui
                mmltk_tests_model_rfdetr
                mmltk_browser_app_check
            )
            executables=(mmltk_tests_core mmltk_tests_gui mmltk_tests_model_rfdetr)
            ;;
        *)
            print_test_suites >&2
            die "unknown test suite '${suite}'"
            ;;
    esac

    acquire_mutation_locks
    ensure_docker
    prepare_cache_layout
    ensure_build_image
    local target_list="${targets[*]}"
    log "building cached ${suite} test graph with ${build_jobs} workers"
    run_toolchain_command \
        "set -euo pipefail
         cargo fetch --locked \
             --manifest-path /workspace/src/browser/app/Cargo.toml \
             --target wasm32-unknown-unknown
         /workspace/utilities/configure_cmake_graph.sh \
             release \"\${MMLTK_CONTAINER_CACHE_ROOT}/cmake/release\" \
             -DMMLTK_BROWSER_APP_STAGE_DIR=\"\${MMLTK_CONTAINER_BROWSER_STAGE_ROOT}\" \
             -DMMLTK_BROWSER_APP_STATE_DIR=\"\${MMLTK_BROWSER_APP_STATE_DIR}\" \
             -DMMLTK_BUILD_JOBS=\"\${MMLTK_JOBS}\" \
             -DMMLTK_FIREFOX_CACHE_ROOT=\"\${MMLTK_FIREFOX_CACHE_ROOT}\"
         cmake --build \"\${MMLTK_CONTAINER_CACHE_ROOT}/cmake/release\" \
             --parallel \"\${MMLTK_JOBS}\" --target ${target_list}"

    local first_failure=0
    local executable
    for executable in "${executables[@]}"; do
        log "running ${executable}"
        local exit_status=0
        if run_test_executable "${container_cache_root}/cmake/release/${executable}" "$@"; then
            continue
        else
            exit_status=$?
        fi
        if (( first_failure == 0 )); then
            first_failure="${exit_status}"
        fi
        if [[ "${suite}" != "all" ]]; then
            release_mutation_locks
            return "${exit_status}"
        fi
    done
    release_mutation_locks
    return "${first_failure}"
}

prepare_release_build_environment() {
    acquire_mutation_locks
    ensure_docker
    prepare_cache_layout
}

run_build() {
    acquire_mutation_locks
    initialize_build_trace
    trace_build_event build start
    trace_build_job_assignment
    trace_failed_build() {
        local exit_status=$?
        trap - ERR
        trace_build_event build finish "failure:${exit_status}"
        return "${exit_status}"
    }
    trap trace_failed_build ERR
    run_traced_build_phase bootstrap prepare_release_build_environment
    run_traced_build_phase buildx ensure_buildx_builder
    buildx_builder_ready=1
    docker rm -f "${release_build_container_name}" >/dev/null 2>&1 || true
    active_build_container_names=("${release_build_container_name}")
    run_traced_build_phase release_ninja run_release_branch &
    active_build_pids+=("$!")
    run_traced_build_phase runtime_base ensure_runtime_base_image &
    active_build_pids+=("$!")
    if wait_for_parallel_builds; then
        :
    else
        local exit_status=$?
        trap - ERR
        trace_build_event build finish "failure:${exit_status}"
        return "${exit_status}"
    fi
    run_traced_build_phase package stage_release_and_runtime
    release_mutation_locks
    trace_build_event build finish success
    trap - ERR
}

