fingerprint_path() {
    local root="$1"
    if [[ -d "${root}" ]]; then
        (
            cd "${root}"
            printf 'directory\0'
            local relative_path
            while IFS= read -r -d '' relative_path; do
                printf '%s\0%s\0' "$(stat -c '%a' -- "${relative_path}")" "${relative_path}"
                if [[ -L "${relative_path}" ]]; then
                    printf 'link\0%s\0' "$(readlink -- "${relative_path}")"
                else
                    sha256sum -- "${relative_path}" | cut -d' ' -f1
                fi
            done < <(find . \( -type f -o -type l \) -print0 | sort -z)
        ) | sha256sum | cut -d' ' -f1
    elif [[ -f "${root}" || -L "${root}" ]]; then
        {
            printf 'file\0%s\0' "$(stat -c '%a' -- "${root}")"
            if [[ -L "${root}" ]]; then
                printf 'link\0%s\0' "$(readlink -- "${root}")"
            else
                sha256sum -- "${root}" | cut -d' ' -f1
            fi
        } | sha256sum | cut -d' ' -f1
    else
        printf 'missing\n' | sha256sum | cut -d' ' -f1
    fi
}

release_package_fingerprint() {
    local release_root="${cmake_cache_root}/release"
    local toolchain_identity
    toolchain_identity="$(docker image inspect "${build_image_name}" --format '{{.Id}}')"
    {
        printf 'mmltk-release-package-v2\n%s\n' "${toolchain_identity}"
        local output_path
        for output_path in \
            mmltk \
            mmltk-browser-host \
            mmltk-rfdetr-onnx-info \
            mmltk-rfdetr-onnx-simplify \
            libmmltk_core.so \
            libmmltk_logging.so \
            libmmltk_rfdetr_native.so; do
            printf '%s %s\n' "${output_path}" \
                "$(fingerprint_path "${release_root}/${output_path}")"
        done
        while IFS= read -r -d '' output_path; do
            printf '%s %s\n' "${output_path#"${release_root}/"}" \
                "$(fingerprint_path "${output_path}")"
        done < <(find "${release_root}" -type f -name cmake_install.cmake -print0 | sort -z)
        printf 'browser %s\n' "$(fingerprint_path "${gui_build_dist_dir}")"
        printf 'firefox %s\n' \
            "$(fingerprint_path "${firefox_cache_root}/obj-minimal-opt/dist/firefox")"
        printf 'python-checkpoint %s\n' \
            "$(fingerprint_path "${repo_root}/utilities/rfdetr_checkpoint_bridge.py")"
        printf 'python-vast %s\n' \
            "$(fingerprint_path "${repo_root}/utilities/vast_bridge.py")"
    } | sha256sum | cut -d' ' -f1
}

release_stage_complete() {
    local stage_root="$1"
    local required_path
    for required_path in \
        bin/mmltk \
        bin/mmltk-browser-host \
        lib/mmltk/firefox/firefox \
        lib/mmltk/firefox/firefox-bin \
        lib/mmltk/firefox/libxul.so \
        lib/mmltk/firefox/libmozgtk.so \
        lib/mmltk/firefox/libmozwayland.so \
        lib/mmltk/firefox/application.ini \
        lib/mmltk/firefox/platform.ini \
        lib/mmltk/firefox/omni.ja \
        lib/mmltk/firefox/browser/omni.ja \
        share/mmltk/browser-app/index.html; do
        [[ -e "${stage_root}/${required_path}" ]] || return 1
    done
    return 0
}

native_stage_fingerprint() {
    local stage_root="$1"
    {
        printf 'bin %s\n' "$(fingerprint_path "${stage_root}/bin")"
        printf 'python %s\n' "$(fingerprint_path "${stage_root}/share/mmltk/python")"
        local library_path
        while IFS= read -r -d '' library_path; do
            printf '%s %s\n' "${library_path#"${stage_root}/lib/"}" \
                "$(fingerprint_path "${library_path}")"
        done < <(find "${stage_root}/lib" -maxdepth 1 \
            \( -type f -o -type l \) -print0 | sort -z)
    } | sha256sum | cut -d' ' -f1
}

runtime_image_fingerprint() {
    local stage_root="$1"
    local runtime_base_identity="$2"
    {
        printf 'mmltk-runtime-image-v2\n%s\n' "${runtime_base_identity}"
        sha256sum "${repo_root}/docker/Dockerfile.runtime"
        printf 'native %s\n' "$(native_stage_fingerprint "${stage_root}")"
        printf 'firefox %s\n' \
            "$(fingerprint_path "${stage_root}/lib/mmltk/firefox")"
        printf 'browser %s\n' \
            "$(fingerprint_path "${stage_root}/share/mmltk/browser-app")"
    } | sha256sum | cut -d' ' -f1
}

build_runtime_image() {
    local stage_root="$1"
    local runtime_base_identity
    runtime_base_identity="$(docker image inspect "${runtime_base_image_name}" --format '{{.Id}}')"
    local release_fingerprint
    release_fingerprint="$(runtime_image_fingerprint \
        "${stage_root}" "${runtime_base_identity}")"
    local current_release_fingerprint=""
    local current_runtime_base_identity=""
    if docker image inspect "${image_name}" >/dev/null 2>&1; then
        current_release_fingerprint="$(docker image inspect "${image_name}" \
            --format '{{ index .Config.Labels "com.mmltk.release-fingerprint" }}' \
            2>/dev/null || true)"
        current_runtime_base_identity="$(docker image inspect "${image_name}" \
            --format '{{ index .Config.Labels "com.mmltk.runtime-base-identity" }}' \
            2>/dev/null || true)"
    fi
    if [[ "${current_release_fingerprint}" == "${release_fingerprint}" \
        && "${current_runtime_base_identity}" == "${runtime_base_identity}" ]]; then
        log "runtime image is current"
        trace_build_event runtime_image cache_hit
        return 0
    fi

    trace_build_event runtime_image cache_miss
    docker buildx inspect default >/dev/null || die \
        "Docker's default Engine-backed Buildx builder is unavailable"
    docker buildx build \
        --builder default \
        --progress=plain \
        --load \
        --file "${repo_root}/docker/Dockerfile.runtime" \
        --build-arg "MMLTK_RUNTIME_BASE_IMAGE=${runtime_base_image_name}" \
        --build-arg "MMLTK_RELEASE_FINGERPRINT=${release_fingerprint}" \
        --build-arg "MMLTK_RUNTIME_BASE_IDENTITY=${runtime_base_identity}" \
        --tag "${image_name}" \
        "${stage_root}"
    current_release_fingerprint="$(docker image inspect "${image_name}" \
        --format '{{ index .Config.Labels "com.mmltk.release-fingerprint" }}')"
    current_runtime_base_identity="$(docker image inspect "${image_name}" \
        --format '{{ index .Config.Labels "com.mmltk.runtime-base-identity" }}')"
    [[ "${current_release_fingerprint}" == "${release_fingerprint}" ]] || die \
        "runtime image release fingerprint label does not match staged outputs"
    [[ "${current_runtime_base_identity}" == "${runtime_base_identity}" ]] || die \
        "runtime image base identity label does not match ${runtime_base_image_name}"
}

stage_release_and_runtime() {
    local package_fingerprint
    package_fingerprint="$(release_package_fingerprint)"
    if release_stage_complete "${release_stage_root}" \
        && [[ -f "${release_stage_root}/.mmltk-package-fingerprint" ]] \
        && [[ "$(<"${release_stage_root}/.mmltk-package-fingerprint")" == "${package_fingerprint}" ]]; then
        log "staged release is current"
        trace_build_event package cache_hit
        build_runtime_image "${release_stage_root}"
        return
    fi

    trace_build_event package cache_miss
    local next_stage="${release_stage_root}.next"
    export MMLTK_PACKAGE_FINGERPRINT="${package_fingerprint}"
    log "installing release into ${next_stage}"
    run_toolchain_command \
        'set -euo pipefail
         next_stage="${MMLTK_CONTAINER_RELEASE_STAGE_ROOT}.next"
         rm -rf -- "${next_stage}"
         cmake --install "${MMLTK_CONTAINER_CACHE_ROOT}/cmake/release" \
             --prefix "${next_stage}"
         printf "%s\n" "${MMLTK_PACKAGE_FINGERPRINT}" >"${next_stage}/.mmltk-package-fingerprint"'
    unset MMLTK_PACKAGE_FINGERPRINT
    release_stage_complete "${next_stage}" || die "staged release is incomplete"
    [[ -f "${next_stage}/.mmltk-package-fingerprint" \
        && "$(<"${next_stage}/.mmltk-package-fingerprint")" == "${package_fingerprint}" ]] \
        || die "staged release fingerprint is incomplete"

    build_runtime_image "${next_stage}"
    local previous_stage="${release_stage_root}.previous"
    rm -rf -- "${previous_stage}"
    if [[ -e "${release_stage_root}" ]]; then
        mv "${release_stage_root}" "${previous_stage}"
    fi
    mv "${next_stage}" "${release_stage_root}"
    rm -rf -- "${previous_stage}"
}

wait_for_parallel_builds() {
    local remaining="${#active_build_pids[@]}"
    local exit_status=0
    while (( remaining > 0 )); do
        if wait -n; then
            remaining=$((remaining - 1))
        else
            exit_status=$?
            log "parallel build job failed with exit status ${exit_status}; stopping its peer"
            terminate_active_builds
            return "${exit_status}"
        fi
    done
    active_build_pids=()
    active_build_container_names=()
}

