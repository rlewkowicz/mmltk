Library("verifymar")

UNIFIED_SOURCES += [
    "cryptox.c",
    "mar_verify.c",
]

FORCE_STATIC_LIB = True

USE_LIBS += [
    "nspr",
    "nss",
    "signmar",
]
OS_LIBS += [
    "-Wl,-rpath=\\$$ORIGIN",
]

LOCAL_INCLUDES += [
    "../src",
]

if CONFIG["MOZ_USE_NSS_FOR_MAR"]:
    LOCAL_INCLUDES += ["../sign"]
    DEFINES["MAR_NSS"] = True
