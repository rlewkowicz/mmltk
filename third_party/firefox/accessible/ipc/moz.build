LOCAL_INCLUDES += ['/accessible/atk']
if CONFIG['ACCESSIBILITY']:
    IPDL_SOURCES += ['DocAccessibleTypes.ipdlh']
    IPDL_SOURCES += ['PDocAccessible.ipdl']
EXPORTS.mozilla.a11y += ['IPCTypes.h']
if CONFIG['ACCESSIBILITY']:
    EXPORTS.mozilla.a11y += ['DocAccessibleChild.h', 'DocAccessibleParent.h', 'RemoteAccessible.h']
    UNIFIED_SOURCES += ['DocAccessibleChild.cpp', 'DocAccessibleParent.cpp', 'RemoteAccessible.cpp']
    LOCAL_INCLUDES += ['/accessible/base', '/accessible/generic', '/accessible/xpcom']
include('/ipc/chromium/chromium-config.mozbuild')
FINAL_LIBRARY = 'xul'
