ReplaceMalloc("logalloc")

SOURCES += [
    "LogAlloc.cpp",
]

# FdPrintf is statically linked when mozjemalloc is not statically linked.
if not CONFIG["MOZ_REPLACE_MALLOC_STATIC"]:
    SOURCES += [
        "/memory/build/FdPrintf.cpp",
    ]

DisableStlWrapping()
NO_PGO = True
DEFINES["MOZ_NO_MOZALLOC"] = True

LOCAL_INCLUDES += [
    "/memory/build",
]

