SOURCES += [
    "../FileUtils.cpp",
    "../MemUtils.cpp",
    "nsXPCOMGlue.cpp",
]

Library("xpcomglue")

FORCE_STATIC_LIB = True


DEFINES["XPCOM_GLUE"] = True

LOCAL_INCLUDES += [
    "../../build",
    "../../threads",
]

# Don't use STL wrappers here (i.e. wrapped <new>); they require mozalloc
DisableStlWrapping()

DIST_INSTALL = True

CXXFLAGS += CONFIG["GLIB_CFLAGS"]
