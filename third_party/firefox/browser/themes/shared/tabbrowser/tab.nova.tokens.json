{
  "margin": {
    "block": {
      "value": "6px"
    }
  },
  "border": {
    "radius": {
      "value": "{toolbarbutton.border.radius}"
    },
    "color": {
      "accent": {
        "value": "linear-gradient(96deg, var(--tab-border-color-selected-leading) 20.68%, var(--tab-border-color-selected-trailing) 79.34%)"
      },
      "selected": {
        "leading": {
          "value": "{color.violet.30}"
        },
        "trailing": {
          "value": {
            "light": "{color.orange.30}",
            "dark": "{color.violet.50}"
          }
        }
      }
    }
  },
  "box": {
    "shadow": {
      "selected": {
        "value": "none"
      }
    }
  },
  "background": {
    "color": {
      "hover": {
        "value": {
          "nativeTheme": "color-mix(in srgb, currentColor 17%, transparent)",
          "default": "{toolbarbutton.background.color.hover}"
        }
      },
      "selected": {
        "value": {
          "nativeTheme": "var(--toolbar-background-color)",
          "default": "{background.color.box.@base}"
        }
      }
    }
  },
  "loading": {
    "fill": {
      "value": "{color.accent.primary.@base}"
    }
  },
  "outline": {
    "offset": {
      "value": "-1px"
    }
  },
  "group": {
    "blue": {
      "@base": {
        "value": {
          "light": "{color.blue.50}",
          "dark": "{color.blue.30}"
        }
      },
      "text": {
        "@base": {
          "value": {
            "light": "{color.white.@base}",
            "dark": "{color.blue.90}"
          }
        }
      },
      "hover": {
        "value": {
          "light": "{color.blue.60}",
          "dark": "{color.blue.40}"
        }
      }
    },
    "purple": {
