GeneratedFile(
    "channel-prefs.js",
    script="generate_channel_prefs.py",
    inputs=["profile/channel-prefs.js"],
)
FINAL_TARGET_FILES.defaults.pref += ["!channel-prefs.js"]

if CONFIG["MOZ_MACBUNDLE_NAME"]:
    DIRS += ["macbuild/Contents"]

browser_linkage = "standalone"
if CONFIG["MOZ_NO_PIE_COMPAT"]:
    GeckoProgram(CONFIG["MOZ_APP_NAME"] + "-bin", linkage=browser_linkage)

    DIRS += ["no-pie"]
else:
    GeckoProgram(CONFIG["MOZ_APP_NAME"], linkage=browser_linkage)

# Compile the application data (which changes every build due to the build ID)
# in a separate tiny file so that nsBrowserApp.cpp doesn't need to be
# recompiled on every no-op build.
SOURCES += [
    "ApplicationData.cpp",
    "nsBrowserApp.cpp",
]

# Neither channel-prefs.js nor firefox.exe want to end up in dist/bin/browser.
DIST_SUBDIR = ""

LOCAL_INCLUDES += [
    "!/build",
    "/toolkit/xre",
    "/xpcom/base",
    "/xpcom/build",
]



if CONFIG["DESKTOP_LAUNCHER_ENABLED"]:
    DIRS += [
        "desktop-launcher",
    ]



# Control the default heap size.
# This is the heap returned by GetProcessHeap().
# As we use the CRT heap, the default size is too large and wastes VM.
#
# The heap will grow if need be.
#
# Set it to 256k.  See bug 127069.

DisableStlWrapping()

if CONFIG["HAVE_CLOCK_MONOTONIC"]:
    OS_LIBS += CONFIG["REALTIME_LIBS"]

OS_LIBS += CONFIG["DL_LIBS"]

if CONFIG["MOZ_LINUX_32_SSE2_STARTUP_ERROR"]:
    DEFINES["MOZ_LINUX_32_SSE2_STARTUP_ERROR"] = True
    COMPILE_FLAGS["OS_CXXFLAGS"] = [
        f
        for f in COMPILE_FLAGS["OS_CXXFLAGS"]
        if not f.startswith("-march=") and f not in ("-msse", "-msse2", "-mfpmath=sse")
    ] + [
        "-mno-sse",
        "-mno-sse2",
        "-mfpmath=387",
    ]

for icon in ("firefox", "document", "newwindow", "newtab", "pbmode"):
    DEFINES[icon.upper() + "_ICO"] = '"%s/%s/%s.ico"' % (
        TOPSRCDIR,
        CONFIG["MOZ_BRANDING_DIRECTORY"],
        icon,
    )

if CONFIG["MOZ_ASAN"] or CONFIG["MOZ_DEBUG"]:
    WINCONSOLE = True
else:
    WINCONSOLE = False
