if CONFIG["COMPILE_ENVIRONMENT"]:
    EXPORTS.mozilla += [
        "!origin_trials_ffi_generated.h",
    ]

    CbindgenHeader(
        "origin_trials_ffi_generated.h",
        inputs=["ffi"],
    )

    GeneratedFile(
        "keys.inc",
        script="gen-keys.py",
        entry_point="generate",
        inputs=["prod.pub"],
    )

EXPORTS.mozilla += [
    "OriginTrials.h",
    "OriginTrialsIPCUtils.h",
]

UNIFIED_SOURCES += [
    "OriginTrials.cpp",
]

include("/ipc/chromium/chromium-config.mozbuild")

FINAL_LIBRARY = "xul"
