XPIDL_SOURCES += [
    "nsIIndexedDatabaseManager.idl",
]

XPIDL_MODULE = "dom_indexeddb"

EXPORTS.mozilla.dom += [
    "DatabaseFileInfoFwd.h",
    "FlippedOnce.h",
    "IDBCursor.h",
    "IDBCursorType.h",
    "IDBDatabase.h",
    "IDBEvents.h",
    "IDBFactory.h",
    "IDBIndex.h",
    "IDBKeyRange.h",
    "IDBObjectStore.h",
    "IDBRecord.h",
    "IDBRequest.h",
    "IDBTransaction.h",
    "IndexedDatabase.h",
    "IndexedDatabaseManager.h",
    "SafeRefPtr.h",
]

EXPORTS.mozilla.dom.indexedDB += [
    "ActorsChild.h",
    "ActorsParent.h",
    "IDBResult.h",
    "Key.h",
    "KeyPath.h",
    "SerializationHelpers.h",
    "ThreadLocal.h",
    "TransactionOpResult.h",
]

XPCOM_MANIFESTS += [
    "components.conf",
]

UNIFIED_SOURCES += [
    "ActorsChild.cpp",
    "ActorsParentCommon.cpp",
    "DatabaseFileInfo.cpp",
    "DBSchema.cpp",
    "IDBCursor.cpp",
    "IDBCursorType.cpp",
    "IDBDatabase.cpp",
    "IDBEvents.cpp",
    "IDBFactory.cpp",
    "IDBGetAllOptions.cpp",
    "IDBIndex.cpp",
    "IDBKeyRange.cpp",
    "IDBObjectStore.cpp",
    "IDBRecord.cpp",
    "IDBRequest.cpp",
    "IDBTransaction.cpp",
    "IndexedDatabase.cpp",
    "IndexedDatabaseManager.cpp",
    "IndexedDBCommon.cpp",
    "KeyPath.cpp",
    "LoggingHelpers.cpp",
    "ReportInternalError.cpp",
    "SchemaUpgrades.cpp",
    "ScriptErrorHelper.cpp",
    "TransactionOpResult.cpp",
]

SOURCES += [
    "ActorsParent.cpp",  # This file is huge.
    "Key.cpp",  # We disable a warning on this file only
]

IPDL_SOURCES += [
    "PBackgroundIDBCursor.ipdl",
    "PBackgroundIDBDatabase.ipdl",
    "PBackgroundIDBDatabaseFile.ipdl",
    "PBackgroundIDBFactory.ipdl",
    "PBackgroundIDBFactoryRequest.ipdl",
    "PBackgroundIDBRequest.ipdl",
    "PBackgroundIDBSharedTypes.ipdlh",
    "PBackgroundIDBTransaction.ipdl",
    "PBackgroundIDBVersionChangeTransaction.ipdl",
    "PBackgroundIndexedDBUtils.ipdl",
]

include("/ipc/chromium/chromium-config.mozbuild")

FINAL_LIBRARY = "xul"

SOURCES["Key.cpp"].flags += ["-Wno-error=type-limits"]

LOCAL_INCLUDES += [
    "/dom/base",
    "/dom/storage",
    "/ipc/glue",
    "/third_party/sqlite3/src",
    "/xpcom/build",
]

XPIDL_SOURCES += [
    "nsIIDBPermissionsRequest.idl",
]

XPIDL_MODULE = "dom_indexeddb"
