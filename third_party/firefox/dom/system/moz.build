# This picks up *hapticfeedback* which is graveyard
toolkit = CONFIG["MOZ_WIDGET_TOOLKIT"]

DIRS += ["linux"]

EXPORTS += [
    "nsOSPermissionRequest.h",
]

XPIDL_SOURCES += [
    "nsIOSPermissionRequest.idl",
]

XPIDL_MODULE = "dom_system"

EXPORTS += [
    "nsDeviceSensors.h",
    "nsOSPermissionRequestBase.h",
]

UNIFIED_SOURCES += [
    "nsDeviceSensors.cpp",
    "nsOSPermissionRequestBase.cpp",
]

MOZ_SRC_FILES += [
    "NetworkGeolocationProvider.sys.mjs",
]

XPCOM_MANIFESTS += [
    "components.conf",
]

include("/ipc/chromium/chromium-config.mozbuild")

FINAL_LIBRARY = "xul"
# We fire the nsDOMDeviceAcceleration
LOCAL_INCLUDES += [
    "/dom/base",
    "/dom/bindings",
    "/js/xpconnect/loader",
    "/xpcom/base",
]
