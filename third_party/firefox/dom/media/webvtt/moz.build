EXPORTS.mozilla.dom += [
    "HTMLTrackElement.h",
    "TextTrack.h",
    "TextTrackCue.h",
    "TextTrackCueList.h",
    "TextTrackList.h",
    "TextTrackManager.h",
    "TextTrackRegion.h",
    "WebVTTListener.h",
]

UNIFIED_SOURCES += [
    "HTMLTrackElement.cpp",
    "TextTrack.cpp",
    "TextTrackCue.cpp",
    "TextTrackCueList.cpp",
    "TextTrackList.cpp",
    "TextTrackManager.cpp",
    "TextTrackRegion.cpp",
    "WebVTTListener.cpp",
]

XPIDL_SOURCES += [
    "nsIWebVTTListener.idl",
    "nsIWebVTTParserWrapper.idl",
]

XPIDL_MODULE = "webvtt"

EXTRA_JS_MODULES += [
    "WebVTTParserWrapper.sys.mjs",
]

XPCOM_MANIFESTS += [
    "components.conf",
]

EXTRA_JS_MODULES += [
    "vtt.sys.mjs",
]





FINAL_LIBRARY = "xul"
