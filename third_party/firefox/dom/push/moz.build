EXTRA_COMPONENTS += [
    "Push.manifest",
]

EXTRA_JS_MODULES += [
    "ChromePushSubscription.sys.mjs",
    "Push.sys.mjs",
    "PushBroadcastService.sys.mjs",
    "PushComponents.sys.mjs",
    "PushCrypto.sys.mjs",
    "PushDB.sys.mjs",
    "PushRecord.sys.mjs",
    "PushService.sys.mjs",
]

EXTRA_JS_MODULES += [
    "PushServiceWebSocket.sys.mjs",
]

XPCOM_MANIFESTS += [
    "components.conf",
]

XPIDL_SOURCES += [
    "nsIPushErrorReporter.idl",
    "nsIPushNotifier.idl",
    "nsIPushService.idl",
]

XPIDL_MODULE = "dom_push"

EXPORTS.mozilla.dom += [
    "PushManager.h",
    "PushNotifier.h",
    "PushSubscription.h",
    "PushSubscriptionOptions.h",
]

UNIFIED_SOURCES += [
    "PushManager.cpp",
    "PushNotifier.cpp",
    "PushSubscription.cpp",
    "PushSubscriptionOptions.cpp",
]

include("/ipc/chromium/chromium-config.mozbuild")

LOCAL_INCLUDES += [
    "../base",
    "../ipc",
]

FINAL_LIBRARY = "xul"
