EXPORTS.mozilla.dom += [
    "DocumentL10n.h",
    "DOMLocalization.h",
    "L10nMutations.h",
    "L10nOverlays.h",
]

UNIFIED_SOURCES += [
    "DocumentL10n.cpp",
    "DOMLocalization.cpp",
    "L10nMutations.cpp",
    "L10nOverlays.cpp",
]

LOCAL_INCLUDES += [
    "/dom/base",
    "/toolkit/components/jsoncpp/include",
]

FINAL_LIBRARY = "xul"
