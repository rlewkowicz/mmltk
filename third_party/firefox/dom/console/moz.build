XPIDL_SOURCES += [
    "nsIConsoleAPIStorage.idl",
]

XPIDL_MODULE = "dom"

EXPORTS += [
    "nsIConsoleReportCollector.h",
]

EXPORTS.mozilla += [
    "ConsoleReportCollector.h",
]

EXPORTS.mozilla.dom += [
    "Console.h",
    "ConsoleInstance.h",
    "ConsoleReportIPCUtils.h",
    "ConsoleUtils.h",
]

UNIFIED_SOURCES += [
    "Console.cpp",
    "ConsoleInstance.cpp",
    "ConsoleReportCollector.cpp",
    "ConsoleUtils.cpp",
]

EXTRA_JS_MODULES += [
    "ConsoleAPIStorage.sys.mjs",
]

XPCOM_MANIFESTS += [
    "components.conf",
]

LOCAL_INCLUDES += [
    "/docshell/base",
    "/dom/base",
    "/js/xpconnect/src",
]

include("/ipc/chromium/chromium-config.mozbuild")

FINAL_LIBRARY = "xul"
