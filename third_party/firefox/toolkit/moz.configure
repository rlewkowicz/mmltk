# Per-format extra args passed to mozbuild.action.package
# ==============================================================
@depends(
    moz_pkg_format,
    enable_profile_use,
)
@imports("shlex")
def moz_package_extra_args(
    pkg_format,
    profile_use,
):
    args = []
    # For non-shippable builds, we would rather finish the build sooner
    # than have optimal compression.
    if pkg_format == "XZ" and profile_use:
        args.append("--strong-compression")
    return " ".join(shlex.quote(a) for a in args)


set_config("MOZ_PACKAGE_EXTRA_ARGS", moz_package_extra_args)


