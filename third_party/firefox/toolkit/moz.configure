@depends(target, "MOZ_PKG_PLATFORM", "MOZ_PKG_SPECIAL")
def moz_pkg_platform(target, override, special):
    if override:
        platform = override[0]
    else:
        # target.raw_os and target.raw_cpu can be unintuitive; hardcode
        # the well-known platforms.
        platform = f"{target.raw_os}-{target.raw_cpu}"
        if target.raw_os == "linux-gnu":
            platform = f"linux-{target.raw_cpu}"
    if special:
        platform = f"{platform}-{special[0]}"
    return platform


set_config("MOZ_PKG_PLATFORM", moz_pkg_platform)


@depends(moz_pkg_platform, "MOZ_SIMPLE_PACKAGE_NAME")
def pkg_langpack_path(platform, simple_name):
    if simple_name:
        return ""
    return f"{platform}/xpi/"


set_config("PKG_LANGPACK_PATH", pkg_langpack_path)


