DEFINES["HAVE_SHELL_SERVICE_BOOL"] = "true"

EXTRA_PP_JS_MODULES += [
    "AppConstants.sys.mjs",
]
# `AppConstants.sys.mjs` does `#include @TOPOBJDIR@/source-repo.h` and
# `#include @TOPOBJDIR@/buildid.h`. The preprocessor opens those at
# build time so they must exist before the preprocess step runs.
PP_FILES_EXTRA_DEPS += ["!/buildid.h", "!/source-repo.h"]

EXTRA_JS_MODULES += [
    "ClipboardContextMenu.sys.mjs",
    "LightweightThemeConsumer.sys.mjs",
]

DIRS += [
    "subprocess",
]

DEFINES["MOZ_GOOGLE_LOCATION_SERVICE_API_KEY"] = (
    CONFIG["MOZ_GOOGLE_LOCATION_SERVICE_API_KEY"] or ""
)


for var in (
    "MOZ_APP_NAME",
    "MOZ_APP_BASENAME",
    "MOZ_APP_DISPLAYNAME",
    "MOZ_APP_VERSION",
    "MOZ_APP_VERSION_DISPLAY",
    "MOZ_BING_API_CLIENTID",
    "MOZ_BING_API_KEY",
    "MOZ_MACBUNDLE_ID",
    "MOZ_MACBUNDLE_NAME",
    "MOZ_MOZILLA_API_KEY",
    "MOZ_WIDGET_TOOLKIT",
    "DLL_PREFIX",
    "DLL_SUFFIX",
    "DEBUG_JS_MODULES",
    "OMNIJAR_NAME",
):
    DEFINES[var] = CONFIG[var] or ""

for var in (
    "MOZ_FOLD_LIBS",
    "MOZ_SYSTEM_NSS",
    "MOZ_SYSTEM_POLICIES",
    "MOZ_UPDATER",
):
    if CONFIG[var]:
        DEFINES[var] = True

for var in (
    "NIGHTLY_BUILD",
    "ENABLE_EXPLICIT_RESOURCE_MANAGEMENT",
    "RELEASE_OR_BETA",
    "EARLY_BETA_OR_EARLIER",
    "MOZ_ESR",
    "ACCESSIBILITY",
    "MOZILLA_OFFICIAL",
    "MOZ_OFFICIAL_BRANDING",
    "MOZ_DEV_EDITION",
    "MOZ_UPDATER",
    "MOZ_MINIMAL_BROWSER",
    "MOZ_NORMANDY",
    "MOZ_MAINTENANCE_SERVICE",
    "MOZ_BACKGROUNDTASKS",
    "MOZ_UPDATE_AGENT",
    "MOZ_DEBUG",
    "MOZ_ASAN",
    "MOZ_TSAN",
    "MOZ_SYSTEM_NSS",
    "MOZ_PLACES",
    "MOZ_GECKOVIEW_HISTORY",
    "MOZ_CODE_COVERAGE",
    "MOZ_JXL",
    "MOZ_SYSTEM_POLICIES",
    "MOZ_SELECTABLE_PROFILES",
    "USE_LIBZ_RS",
):
    DEFINES[f"{var}_BOOL"] = "true" if CONFIG[var] else "false"

JAR_MANIFESTS += ["jar.mn"]

DEFINES["TOPOBJDIR"] = TOPOBJDIR

XPIDL_SOURCES += [
    "nsIBrowserWindowTracker.idl",
    "nsIRegion.idl",
]

XPIDL_MODULE = "toolkit_modules"

MOZ_SRC_FILES += [
    "PrefUtils.sys.mjs",
    "WebAuthnPromptHelper.sys.mjs",
]
