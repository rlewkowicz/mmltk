UNIFIED_SOURCES += [
    'json_reader.cpp',
    'json_value.cpp',
    'json_writer.cpp'
]

LOCAL_INCLUDES += [
    '/toolkit/components/jsoncpp/include',
]

# Required because JsonCpp is linked outside libxul.
DisableStlWrapping()

Library('jsoncpp')

# Suppress warnings in third-party code.
CXXFLAGS += [
    '-Wno-unused-local-typedefs',
]

CXXFLAGS += [
    '-Wno-c++11-narrowing',
]

CXXFLAGS += [
    '-Wno-implicit-fallthrough',
]
