+void CefFrameHostImpl::ReleaseWorkspaceGpuBridgeSurface(
+    const std::string& surface_id,
+    const std::string& revision,
+    bool renderer_dissociated) {
+  if (!CEF_CURRENTLY_ON_UIT()) {
+    CEF_POST_TASK(
+        CEF_UIT,
+        base::BindOnce(&CefFrameHostImpl::ReleaseWorkspaceGpuBridgeSurface,
+                       this, surface_id, revision, renderer_dissociated));
+    return;
+  }
+
+  auto* render_frame_host = GetRenderFrameHost();
+  if (!render_frame_host) {
+    return;
+  }
+
+  CefWorkspaceGpuBridgeSurfaceService::GetInstance().Release(
+      render_frame_host, surface_id, revision, renderer_dissociated);
+}
