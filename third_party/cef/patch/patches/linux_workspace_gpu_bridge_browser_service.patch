+
+CefWorkspaceGpuBridgeSurfaceService&
+CefWorkspaceGpuBridgeSurfaceService::GetInstance() {
+  static base::NoDestructor<CefWorkspaceGpuBridgeSurfaceService> instance;
+  return *instance;
+}
+
+std::string CefWorkspaceGpuBridgeSurfaceService::MakeKey(
+    std::string_view surface_id,
+    std::string_view revision) {
+  return std::string(surface_id) + '\n' + std::string(revision);
+}
+
+bool CefWorkspaceGpuBridgeSurfaceService::ExportForBrowser(
+    content::RenderFrameHost* render_frame_host,
+    std::string_view surface_id,
+    std::string_view revision,
+    std::string_view publication_source_json,
+    CefString* exported_shared_image_json_out,
+    CefString* result_code,
+    CefString* result_detail) {
+  (void)render_frame_host;
+  if (!IsWorkspaceSurfaceId(surface_id) || revision.empty()) {
+    SetResult(result_code, result_detail, "invalid_surface",
+              "workspace GPU bridge browser service only supports non-empty "
+              "workspace surface revisions");
+    return false;
+  }
+  const std::string key = MakeKey(surface_id, revision);
+  {
+    base::AutoLock hold(lock_);
+    const auto existing = entries_.find(key);
+    if (existing != entries_.end()) {
+      if (exported_shared_image_json_out) {
+        *exported_shared_image_json_out =
+            existing->second.exported_shared_image_json;
+      }
+      SetResult(result_code, result_detail, "ok", "reused exported SharedImage");
+      return true;
+    }
+  }
+  std::string export_code;
+  std::string export_detail;
+  std::optional<Entry> maybe_entry =
+      CreateExportedSharedImageForDmaBuf(publication_source_json,
+                                         surface_id, revision, &export_code,
+                                         &export_detail);
+  if (!maybe_entry.has_value()) {
+    LOG(WARNING) << "workspace GPU bridge browser export rejected surface "
+                 << surface_id << " revision " << revision << ": "
+                 << export_code << ": " << export_detail;
+    SetResult(result_code, result_detail,
+              export_code.empty() ? "shared_image_creation_failure" : export_code,
+              export_detail.empty()
+                  ? "workspace GPU bridge browser service requires an importable "
+                    "DMA-BUF workspace payload"
+                  : export_detail);
+    return false;
+  }
+  Entry entry = std::move(*maybe_entry);
+  std::string exported_payload;
+  bool inserted = false;
+  {
+    base::AutoLock hold(lock_);
+    auto [it, inserted_entry] = entries_.try_emplace(key, std::move(entry));
+    exported_payload = it->second.exported_shared_image_json;
+    inserted = inserted_entry;
+  }
+  if (exported_shared_image_json_out) {
+    *exported_shared_image_json_out = exported_payload;
+  }
+  SetResult(result_code, result_detail, "ok",
+            inserted ? "exported SharedImage" : "reused exported SharedImage");
+  return true;
+}
+
+bool CefWorkspaceGpuBridgeSurfaceService::Release(
+    content::RenderFrameHost* render_frame_host,
+    std::string_view surface_id,
+    std::string_view revision,
+    bool renderer_dissociated,
+    CefString* result_code,
+    CefString* result_detail) {
+  if (!IsWorkspaceSurfaceId(surface_id) || revision.empty()) {
+    SetResult(result_code, result_detail, "invalid_surface",
+              "workspace GPU bridge release requires workspace surface id and "
+              "revision");
+    return false;
+  }
+  base::AutoLock hold(lock_);
+  const auto it = entries_.find(MakeKey(surface_id, revision));
+  if (it == entries_.end()) {
+    SetResult(result_code, result_detail, "release_failure",
+              "workspace GPU bridge release could not find the surface revision");
+    return false;
+  }
+  if (render_frame_host == nullptr) {
+    it->second.browser_released = true;
+  } else if (renderer_dissociated) {
+    it->second.renderer_associated = true;
+    it->second.renderer_dissociated = true;
+  }
+  if (!it->second.browser_released) {
+    SetResult(result_code, result_detail, "ok", "renderer surface release recorded");
+    LOG(INFO) << "workspace GPU bridge renderer released surface "
+              << surface_id << " revision " << revision;
+    return true;
+  }
+  if (it->second.renderer_associated && it->second.renderer_dissociated) {
+    entries_.erase(it);
+    SetResult(result_code, result_detail, "ok", "browser and renderer surface release completed");
+    LOG(INFO) << "workspace GPU bridge browser released surface "
+              << surface_id << " revision " << revision;
+    return true;
+  }
+  if (!it->second.renderer_associated) {
+    ScheduleUnassociatedRelease(std::string(surface_id), std::string(revision));
+  }
+  SetResult(result_code, result_detail, "ok", "browser surface release recorded");
+  LOG(INFO) << "workspace GPU bridge browser released surface "
+            << surface_id << " revision " << revision;
+  return true;
+}
+
+void CefWorkspaceGpuBridgeSurfaceService::ScheduleUnassociatedRelease(
+    std::string surface_id,
+    std::string revision) {
+  base::SequencedTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(
+          &CefWorkspaceGpuBridgeSurfaceService::EraseBrowserReleasedUnassociated,
+          base::Unretained(this), std::move(surface_id), std::move(revision)),
+      kUnassociatedReleaseGrace);
+}
+
+void CefWorkspaceGpuBridgeSurfaceService::EraseBrowserReleasedUnassociated(
+    std::string surface_id,
+    std::string revision) {
+  base::AutoLock hold(lock_);
+  const auto it = entries_.find(MakeKey(surface_id, revision));
+  if (it == entries_.end() || !it->second.browser_released ||
+      it->second.renderer_associated) {
+    return;
+  }
+  entries_.erase(it);
+}
+
+void CefWorkspaceGpuBridgeSurfaceService::RetainRendererAssociation(
+    content::RenderFrameHost* render_frame_host,
+    std::string_view surface_id,
+    std::string_view revision) {
+  (void)render_frame_host;
+  if (!IsWorkspaceSurfaceId(surface_id) || revision.empty()) {
+    return;
+  }
+  base::AutoLock hold(lock_);
+  const auto it = entries_.find(MakeKey(surface_id, revision));
+  if (it == entries_.end()) {
+    return;
+  }
+  it->second.renderer_associated = true;
+  it->second.renderer_dissociated = false;
+}
+
+extern "C" CEF_EXPORT bool mmltk_cef_workspace_gpu_bridge_export_shared_image(
+    const char* surface_id,
+    size_t surface_id_length,
+    const char* revision,
+    size_t revision_length,
+    const char* publication_source_json,
+    size_t publication_source_json_length,
+    CefString* exported_shared_image_json_out,
+    CefString* result_code,
+    CefString* result_detail) noexcept {
+  if (!surface_id || surface_id_length == 0U || !revision ||
+      revision_length == 0U || !publication_source_json ||
+      publication_source_json_length == 0U) {
+    SetResult(result_code, result_detail, "invalid_surface",
+              "workspace GPU bridge export requires surface id, revision, and "
+              "publication source");
+    return false;
+  }
+  return CefWorkspaceGpuBridgeSurfaceService::GetInstance().ExportForBrowser(
+      /*render_frame_host=*/nullptr,
+      std::string_view(surface_id, surface_id_length),
+      std::string_view(revision, revision_length),
+      std::string_view(publication_source_json,
+                       publication_source_json_length),
+      exported_shared_image_json_out, result_code, result_detail);
+}
+
+extern "C" CEF_EXPORT bool mmltk_cef_workspace_gpu_bridge_release_surface(
+    const char* surface_id,
+    size_t surface_id_length,
+    const char* revision,
+    size_t revision_length,
+    bool renderer_dissociated,
+    CefString* result_code,
+    CefString* result_detail) noexcept {
+  if (!surface_id || surface_id_length == 0U || !revision ||
+      revision_length == 0U) {
+    SetResult(result_code, result_detail, "invalid_surface",
+              "workspace GPU bridge release requires surface id and revision");
+    return false;
+  }
+  return CefWorkspaceGpuBridgeSurfaceService::GetInstance().Release(
+      /*render_frame_host=*/nullptr,
+      std::string_view(surface_id, surface_id_length),
+      std::string_view(revision, revision_length), renderer_dissociated,
+      result_code, result_detail);
+}
