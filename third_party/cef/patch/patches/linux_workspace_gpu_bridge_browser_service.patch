+std::optional<uint32_t> ParseUint32(const base::Value& value) {
+  if (const auto int_value = value.GetIfInt()) {
+    if (*int_value >= 0) {
+      return static_cast<uint32_t>(*int_value);
+    }
+  }
+  if (const std::string* string_value = value.GetIfString()) {
+    uint32_t parsed = 0;
+    if (base::StringToUint(*string_value, &parsed)) {
+      return parsed;
+    }
+  }
+  return std::nullopt;
+}
+
+std::optional<uint64_t> ParseUint64(const base::Value& value) {
+  if (const std::string* string_value = value.GetIfString()) {
+    uint64_t parsed = 0;
+    if (base::StringToUint64(*string_value, &parsed)) {
+      return parsed;
+    }
+  }
+  if (const auto int_value = value.GetIfInt()) {
+    if (*int_value >= 0) {
+      return static_cast<uint64_t>(*int_value);
+    }
+  }
+  if (const auto double_value = value.GetIfDouble()) {
+    if (*double_value >= 0.0 &&
+        *double_value <= static_cast<double>(std::numeric_limits<uint64_t>::max()) &&
+        std::floor(*double_value) == *double_value) {
+      return static_cast<uint64_t>(*double_value);
+    }
+  }
+  return std::nullopt;
+}
+
+bool IsWorkspaceSurfaceId(std::string_view surface_id) {
+  return surface_id == kWorkspaceSurfaceId;
+}
+
+struct DmaBufWorkspaceSource {
+  int fd = -1;
+  int cuda_device_index = -1;
+  uint32_t width = 0;
+  uint32_t height = 0;
+  uint64_t stride_bytes = 0;
+  uint64_t offset = 0;
+  uint64_t allocation_size = 0;
+  uint32_t drm_format = 0;
+  uint64_t drm_modifier = 0;
+  uint32_t modifier_mode = 0;
+  uint32_t ready_sync_kind = 0;
+  uint64_t ready_sync_handle = 0;
+  uint64_t ready_sync_value = 0;
+  uint32_t producer_stream_kind = 0;
+  uint64_t producer_stream_handle = 0;
+  uint32_t release_sync_kind = 0;
+  uint64_t release_sync_handle = 0;
+};
+
+bool ParseDmaBufWorkspaceSource(std::string_view publication_source_json,
+                                DmaBufWorkspaceSource* source,
+                                std::string* result_code,
+                                std::string* result_detail) {
+  std::optional<base::Value> parsed =
+      base::JSONReader::Read(publication_source_json,
+                             base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+  if (!parsed || !parsed->is_dict()) {
+    SetResult(result_code, result_detail, "invalid_dmabuf_metadata",
+              "workspace GPU bridge browser service could not parse "
+              "publication source JSON");
+    return false;
+  }
+  const base::DictValue& root = parsed->GetDict();
+  const base::DictValue* linux_import = root.FindDict("linux_import");
+  const base::DictValue* image = linux_import ? linux_import->FindDict("image")
+                                              : nullptr;
+  if (!image) {
+    SetResult(result_code, result_detail, "invalid_dmabuf_metadata",
+              "workspace GPU bridge browser service requires linux_import.image "
+              "DMA-BUF metadata");
+    return false;
+  }
+
+  const std::optional<uint32_t> kind =
+      image->Find("kind") ? ParseUint32(*image->Find("kind")) : std::nullopt;
+  const std::optional<uint64_t> fd =
+      image->Find("fd") ? ParseUint64(*image->Find("fd")) : std::nullopt;
+  const std::optional<uint32_t> cuda_device_index =
+      image->Find("cuda_device_index")
+          ? ParseUint32(*image->Find("cuda_device_index"))
+          : std::nullopt;
+  const std::optional<uint32_t> width =
+      image->Find("width") ? ParseUint32(*image->Find("width")) : std::nullopt;
+  const std::optional<uint32_t> height =
+      image->Find("height") ? ParseUint32(*image->Find("height"))
+                            : std::nullopt;
+  const std::optional<uint64_t> stride =
+      image->Find("stride_bytes") ? ParseUint64(*image->Find("stride_bytes"))
+                                  : std::nullopt;
+  const std::optional<uint64_t> offset =
+      image->Find("offset") ? ParseUint64(*image->Find("offset")) : std::nullopt;
+  const std::optional<uint64_t> allocation_size =
+      image->Find("allocation_size")
+          ? ParseUint64(*image->Find("allocation_size"))
+          : std::nullopt;
+  const std::optional<uint32_t> drm_format =
+      image->Find("drm_format") ? ParseUint32(*image->Find("drm_format"))
+                                : std::nullopt;
+  const std::optional<uint64_t> drm_modifier =
+      image->Find("drm_modifier") ? ParseUint64(*image->Find("drm_modifier"))
+                                  : std::nullopt;
+  const std::optional<uint32_t> modifier_mode =
+      image->Find("modifier_mode") ? ParseUint32(*image->Find("modifier_mode"))
+                                  : std::nullopt;
+  const base::DictValue* ready_sync = linux_import->FindDict("ready_sync");
+  const base::DictValue* producer_stream =
+      linux_import->FindDict("producer_stream");
+  const base::DictValue* linux_lifecycle = root.FindDict("linux_lifecycle");
+  const base::DictValue* release_sync =
+      linux_lifecycle ? linux_lifecycle->FindDict("release_sync") : nullptr;
+  const std::optional<uint32_t> ready_sync_kind =
+      ready_sync && ready_sync->Find("kind")
+          ? ParseUint32(*ready_sync->Find("kind"))
+          : std::nullopt;
+  const std::optional<uint64_t> ready_sync_handle =
+      ready_sync && ready_sync->Find("handle")
+          ? ParseUint64(*ready_sync->Find("handle"))
+          : std::nullopt;
+  const std::optional<uint64_t> ready_sync_value =
+      ready_sync && ready_sync->Find("value")
+          ? ParseUint64(*ready_sync->Find("value"))
+          : std::nullopt;
+  const std::optional<uint32_t> producer_stream_kind =
+      producer_stream && producer_stream->Find("kind")
+          ? ParseUint32(*producer_stream->Find("kind"))
+          : std::nullopt;
+  const std::optional<uint64_t> producer_stream_handle =
+      producer_stream && producer_stream->Find("handle")
+          ? ParseUint64(*producer_stream->Find("handle"))
+          : std::nullopt;
+  const std::optional<uint32_t> release_sync_kind =
+      release_sync && release_sync->Find("kind")
+          ? ParseUint32(*release_sync->Find("kind"))
+          : std::optional<uint32_t>(0U);
+  const std::optional<uint64_t> release_sync_handle =
+      release_sync && release_sync->Find("handle")
+          ? ParseUint64(*release_sync->Find("handle"))
+          : std::optional<uint64_t>(0U);
+  constexpr uint32_t kDmaBufRgbaKind = 2U;
+  constexpr uint32_t kModifierModeImplicit = 1U;
+  constexpr uint32_t kModifierModeExplicit = 2U;
+  constexpr uint32_t kSyncKindNone = 0U;
+  constexpr uint32_t kSyncKindCudaEvent = 1U;
+  constexpr uint32_t kSyncKindCudaStream = 2U;
+  constexpr uint64_t kDrmFormatModInvalid = (1ULL << 56U) - 1U;
+  const bool valid_modifier =
+      modifier_mode.has_value() &&
+      ((*modifier_mode == kModifierModeImplicit &&
+        drm_modifier.has_value() && *drm_modifier == kDrmFormatModInvalid) ||
+       (*modifier_mode == kModifierModeExplicit &&
+        drm_modifier.has_value() && *drm_modifier != kDrmFormatModInvalid));
+  if (!kind.has_value() || *kind != kDmaBufRgbaKind || !fd.has_value() ||
+      *fd == 0U || *fd > static_cast<uint64_t>(std::numeric_limits<int>::max()) ||
+      !cuda_device_index.has_value() ||
+      *cuda_device_index > static_cast<uint32_t>(std::numeric_limits<int>::max()) ||
+      !width.has_value() || !height.has_value() || *width == 0U ||
+      *width > static_cast<uint32_t>(std::numeric_limits<int>::max()) ||
+      *height == 0U || !stride.has_value() ||
+      *height > static_cast<uint32_t>(std::numeric_limits<int>::max()) ||
+      *stride < static_cast<uint64_t>(*width) * 4U ||
+      *stride > static_cast<uint64_t>(std::numeric_limits<int>::max()) ||
+      !offset.has_value() || !allocation_size.has_value() ||
+      *offset > static_cast<uint64_t>(std::numeric_limits<int>::max()) ||
+      *allocation_size < *offset ||
+      *height > std::numeric_limits<uint64_t>::max() / *stride ||
+      *allocation_size - *offset < *stride * *height ||
+      !drm_format.has_value() || *drm_format != kDrmFormatAbgr8888) {
+    SetResult(result_code, result_detail, "invalid_dmabuf_metadata",
+              "workspace GPU bridge browser service rejected invalid DMA-BUF "
+              "RGBA workspace metadata");
+    return false;
+  }
+  if (!valid_modifier) {
+    SetResult(result_code, result_detail, "unsupported_modifier",
+              "workspace GPU bridge browser service rejected unsupported "
+              "DMA-BUF modifier metadata");
+    return false;
+  }
+  if (!ready_sync_kind.has_value() || *ready_sync_kind != kSyncKindCudaEvent ||
+      !ready_sync_handle.has_value() || *ready_sync_handle == 0U ||
+      !producer_stream_kind.has_value() ||
+      *producer_stream_kind != kSyncKindCudaStream ||
+      !producer_stream_handle.has_value() || *producer_stream_handle == 0U ||
+      !release_sync_kind.has_value() || !release_sync_handle.has_value() ||
+      ((*release_sync_kind != kSyncKindNone) && *release_sync_handle == 0U)) {
+    SetResult(result_code, result_detail, "missing_sync_metadata",
+              "workspace GPU bridge browser service requires CUDA ready event, "
+              "producer stream, and valid release sync metadata");
+    return false;
+  }
+  source->fd = static_cast<int>(*fd);
+  source->cuda_device_index = static_cast<int>(*cuda_device_index);
+  source->width = *width;
+  source->height = *height;
+  source->stride_bytes = *stride;
+  source->offset = *offset;
+  source->allocation_size = *allocation_size;
+  source->drm_format = *drm_format;
+  source->drm_modifier = *drm_modifier;
+  source->modifier_mode = *modifier_mode;
+  source->ready_sync_kind = *ready_sync_kind;
+  source->ready_sync_handle = *ready_sync_handle;
+  source->ready_sync_value = ready_sync_value.value_or(0U);
+  source->producer_stream_kind = *producer_stream_kind;
+  source->producer_stream_handle = *producer_stream_handle;
+  source->release_sync_kind = *release_sync_kind;
+  source->release_sync_handle = *release_sync_handle;
+  return true;
+}
