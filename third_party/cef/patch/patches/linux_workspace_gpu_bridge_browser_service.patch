+base::DictValue SyncTokenToDict(const gpu::SyncToken& sync_token) {
+  base::DictValue dict;
+  dict.Set("verified_flush", sync_token.verified_flush());
+  dict.Set("namespace_id", static_cast<int>(sync_token.namespace_id()));
+  dict.Set("command_buffer_id",
+           base::NumberToString(sync_token.command_buffer_id().GetUnsafeValue()));
+  dict.Set("release_count", base::NumberToString(sync_token.release_count()));
+  return dict;
+}
+
+std::string SerializeSharedImage(scoped_refptr<gpu::ClientSharedImage> shared_image,
+                                 const gpu::SyncToken& creation_sync_token,
+                                 const DmaBufWorkspaceSource& source,
+                                 std::string_view surface_id,
+                                 std::string_view revision) {
+  base::DictValue mailbox;
+  mailbox.Set("name", MailboxBytesToList(shared_image->mailbox()));
+
+  base::DictValue size;
+  size.Set("width", shared_image->size().width());
+  size.Set("height", shared_image->size().height());
+
+  base::DictValue metadata;
+  metadata.Set("size", std::move(size));
+  metadata.Set("format", "rgba8unorm");
+  metadata.Set("usage", static_cast<int>(static_cast<uint32_t>(shared_image->usage())));
+
+  base::DictValue workspace_surface;
+  workspace_surface.Set("surface_id", std::string(surface_id));
+  workspace_surface.Set("revision", std::string(revision));
+  workspace_surface.Set("width", static_cast<int>(source.width));
+  workspace_surface.Set("height", static_cast<int>(source.height));
+  workspace_surface.Set("texture_format", "rgba8unorm");
+
+  base::DictValue dma_buf;
+  dma_buf.Set("fd", base::NumberToString(source.fd));
+  dma_buf.Set("cuda_device_index", source.cuda_device_index);
+  dma_buf.Set("stride_bytes", base::NumberToString(source.stride_bytes));
+  dma_buf.Set("offset", base::NumberToString(source.offset));
+  dma_buf.Set("allocation_size", base::NumberToString(source.allocation_size));
+  dma_buf.Set("drm_format", static_cast<int>(source.drm_format));
+  dma_buf.Set("drm_modifier", base::NumberToString(source.drm_modifier));
+  dma_buf.Set("modifier_mode", static_cast<int>(source.modifier_mode));
+
+  base::DictValue ready_sync;
+  ready_sync.Set("kind", static_cast<int>(source.ready_sync_kind));
+  ready_sync.Set("handle", base::NumberToString(source.ready_sync_handle));
+  ready_sync.Set("value", base::NumberToString(source.ready_sync_value));
+
+  base::DictValue producer_stream;
+  producer_stream.Set("kind", static_cast<int>(source.producer_stream_kind));
+  producer_stream.Set("handle", base::NumberToString(source.producer_stream_handle));
+  producer_stream.Set("value", "0");
+
+  base::DictValue release_sync;
+  release_sync.Set("kind", static_cast<int>(source.release_sync_kind));
+  release_sync.Set("handle", base::NumberToString(source.release_sync_handle));
+  release_sync.Set("value", "0");
+
+  base::DictValue exported;
+  exported.Set("mailbox", std::move(mailbox));
+  exported.Set("metadata", std::move(metadata));
+  exported.Set("workspace_surface", std::move(workspace_surface));
+  exported.Set("dma_buf", std::move(dma_buf));
+  exported.Set("ready_sync", std::move(ready_sync));
+  exported.Set("producer_stream", std::move(producer_stream));
+  exported.Set("release_sync", std::move(release_sync));
+  exported.Set("creation_sync_token", SyncTokenToDict(creation_sync_token));
+  exported.Set("texture_target", static_cast<int>(shared_image->GetTextureTarget()));
+  exported.Set("is_software", shared_image->is_software());
+
+  std::string serialized;
+  CHECK(base::JSONWriter::Write(exported, &serialized));
+  return serialized;
+}
+
+std::optional<CefWorkspaceGpuBridgeSurfaceService::Entry>
+CreateExportedSharedImageForDmaBuf(std::string_view publication_source_json,
+                                   std::string_view surface_id,
+                                   std::string_view revision,
+                                   std::string* result_code,
+                                   std::string* result_detail) {
+  DmaBufWorkspaceSource source;
+  if (!ParseDmaBufWorkspaceSource(publication_source_json, &source,
+                                  result_code, result_detail)) {
+    return std::nullopt;
+  }
+  auto* transport_factory = content::ImageTransportFactory::GetInstance();
+  auto* context_factory =
+      transport_factory ? transport_factory->GetContextFactory() : nullptr;
+  scoped_refptr<viz::RasterContextProvider> context_provider =
+      context_factory ? context_factory->SharedMainThreadRasterContextProvider()
+                      : nullptr;
+  gpu::SharedImageInterface* shared_image_interface =
+      context_provider ? context_provider->SharedImageInterface() : nullptr;
+  if (!shared_image_interface) {
+    SetResult(result_code, result_detail, "shared_image_creation_failure",
+              "workspace GPU bridge browser service has no shared image "
+              "interface for DMA-BUF import");
+    return std::nullopt;
+  }
+
+  int duplicated_fd = ::fcntl(source.fd, F_DUPFD_CLOEXEC, 3);
+  if (duplicated_fd < 0) {
+    SetResult(result_code, result_detail, "invalid_dmabuf_metadata",
+              "workspace GPU bridge browser service failed to duplicate "
+              "the DMA-BUF fd");
+    return std::nullopt;
+  }
+
+  gfx::NativePixmapHandle pixmap_handle;
+  pixmap_handle.modifier = source.drm_modifier;
+  pixmap_handle.planes.emplace_back(
+      base::checked_cast<int>(source.stride_bytes),
+      base::checked_cast<int>(source.offset),
+      source.allocation_size - source.offset,
+      base::ScopedFD(duplicated_fd));
+
+  gpu::SharedImageInfo shared_image_info(
+      viz::SinglePlaneFormat::kRGBA_8888,
+      gfx::Size(base::checked_cast<int>(source.width),
+                base::checked_cast<int>(source.height)),
+      gfx::ColorSpace::CreateSRGB(), kTopLeft_GrSurfaceOrigin,
+      kOpaque_SkAlphaType,
+      gpu::SharedImageUsageSet({gpu::SHARED_IMAGE_USAGE_WEBGPU_READ,
+                                gpu::SHARED_IMAGE_USAGE_DISPLAY_READ}),
+      "mmltk workspace DMA-BUF");
+  scoped_refptr<gpu::ClientSharedImage> shared_image =
+      shared_image_interface->CreateSharedImage(
+          shared_image_info,
+          gfx::GpuMemoryBufferHandle(std::move(pixmap_handle)));
+  if (!shared_image) {
+    SetResult(result_code, result_detail, "shared_image_creation_failure",
+              "workspace GPU bridge browser service failed to import "
+              "DMA-BUF as a SharedImage");
+    return std::nullopt;
+  }
+  if (shared_image->is_software()) {
+    SetResult(result_code, result_detail, "software_shared_image_rejected",
+              "workspace GPU bridge browser service rejected a software "
+              "SharedImage for a live workspace surface");
+    LOG(WARNING) << "workspace GPU bridge rejected software SharedImage "
+                 << surface_id << " revision " << revision;
+    return std::nullopt;
+  }
+
+  gpu::SyncToken creation_sync_token = shared_image->creation_sync_token();
+  if (creation_sync_token.HasData() &&
+      !creation_sync_token.verified_flush()) {
+    shared_image_interface->VerifySyncToken(creation_sync_token);
+  }
+  CefWorkspaceGpuBridgeSurfaceService::Entry entry;
+  entry.exported_shared_image_json =
+      SerializeSharedImage(shared_image, creation_sync_token, source,
+                           surface_id, revision);
+  entry.shared_image = std::move(shared_image);
+  entry.producer_readiness.ready_sync_kind = source.ready_sync_kind;
+  entry.producer_readiness.ready_sync_handle = source.ready_sync_handle;
+  entry.producer_readiness.ready_sync_value = source.ready_sync_value;
+  LOG(INFO) << "workspace GPU bridge created SharedImage " << surface_id
+            << " revision " << revision << " size " << source.width << "x"
+            << source.height << " texture_target "
+            << entry.shared_image->GetTextureTarget() << " usage "
+            << static_cast<uint32_t>(entry.shared_image->usage())
+            << " creation_sync_has_data " << creation_sync_token.HasData()
+            << " creation_sync_verified "
+            << creation_sync_token.verified_flush()
+            << " ready_sync_kind "
+            << entry.producer_readiness.ready_sync_kind
+            << " ready_sync_handle "
+            << entry.producer_readiness.ready_sync_handle
+            << " ready_sync_value "
+            << entry.producer_readiness.ready_sync_value
+            << " dmabuf_modifier " << source.drm_modifier
+            << " dmabuf_stride " << source.stride_bytes;
+  return entry;
+}
