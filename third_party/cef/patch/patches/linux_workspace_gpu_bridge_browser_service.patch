+
+class CefWorkspaceGpuBridgeSurfaceService {
+ public:
+  static CefWorkspaceGpuBridgeSurfaceService& GetInstance();
+
+  CefWorkspaceGpuBridgeSurfaceService(
+      const CefWorkspaceGpuBridgeSurfaceService&) = delete;
+  CefWorkspaceGpuBridgeSurfaceService& operator=(
+      const CefWorkspaceGpuBridgeSurfaceService&) = delete;
+
+  bool ExportForBrowser(content::RenderFrameHost* render_frame_host,
+                        std::string_view surface_id,
+                        std::string_view revision,
+                        std::string_view publication_source_json,
+                        CefString* exported_shared_image_json_out,
+                        CefString* exception);
+
+  void Release(content::RenderFrameHost* render_frame_host,
+               std::string_view surface_id,
+               std::string_view revision,
+               bool renderer_dissociated);
+
+  struct Entry {
+    std::string exported_shared_image_json;
+    bool renderer_dissociated = false;
+  };
+
+ public:
+  CefWorkspaceGpuBridgeSurfaceService() = default;
+
+ private:
+
+  static std::string MakeKey(std::string_view surface_id,
+                             std::string_view revision);
+
+  base::Lock lock_;
+  base::flat_map<std::string, Entry> entries_ GUARDED_BY(lock_);
+};
+
+#endif  // CEF_LIBCEF_BROWSER_WORKSPACE_GPU_BRIDGE_SURFACE_SERVICE_H_
