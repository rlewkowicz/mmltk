+base::ListValue MailboxBytesToList(const gpu::Mailbox& mailbox) {
+  base::ListValue bytes;
+  for (int index = 0; index < GL_MAILBOX_SIZE_CHROMIUM; ++index) {
+    bytes.Append(static_cast<int>(static_cast<uint8_t>(mailbox.name[index])));
+  }
+  return bytes;
+}
