+void CefWorkspaceGpuBridgeSurfaceService::RetireActiveSwapchainLocked() {
+  if (!workspace_swapchain_configured_ && workspace_swapchain_.slots.empty()) {
+    return;
+  }
+  const uint64_t generation = workspace_swapchain_.generation;
+  const bool pending_display_reads =
+      SwapchainHasPendingDisplayReads(workspace_swapchain_);
+  workspace_swapchain_configured_ = false;
+  front_slot_present_log_count_ = 0U;
+  if (pending_display_reads) {
+    retiring_swapchains_.push_back(std::move(workspace_swapchain_));
+    LOG(INFO) << "workspace GPU bridge deferred swapchain cleanup generation "
+              << generation << " retiring_count "
+              << retiring_swapchains_.size();
+  } else {
+    LOG(INFO) << "workspace GPU bridge completed swapchain cleanup generation "
+              << generation;
+  }
+  workspace_swapchain_ = SwapchainState{};
+}
+
+void CefWorkspaceGpuBridgeSurfaceService::PruneRetiredSwapchainsLocked() {
+  for (auto it = retiring_swapchains_.begin();
+       it != retiring_swapchains_.end();) {
+    if (SwapchainHasPendingDisplayReads(*it)) {
+      ++it;
+      continue;
+    }
+    LOG(INFO) << "workspace GPU bridge completed deferred swapchain cleanup "
+              << "generation " << it->generation;
+    it = retiring_swapchains_.erase(it);
+  }
+}
+
+void CefWorkspaceGpuBridgeSurfaceService::
+    OnWorkspaceTransferableResourceReleased(uint64_t generation,
+                                            uint32_t slot_index,
+                                            uint32_t resource_id,
+                                            const gpu::SyncToken& sync_token,
+                                            bool lost_resource) {
+  uint64_t released_revision = 0U;
+  bool released = false;
+  {
+    base::AutoLock hold(lock_);
+    released = ClearPendingSwapchainResource(
+        &workspace_swapchain_, generation, slot_index, resource_id,
+        &released_revision);
+    if (!released) {
+      for (SwapchainState& retiring_swapchain : retiring_swapchains_) {
+        released = ClearPendingSwapchainResource(
+            &retiring_swapchain, generation, slot_index, resource_id,
+            &released_revision);
+        if (released) {
+          break;
+        }
+      }
+    }
+    if (released) {
+      PruneRetiredSwapchainsLocked();
+    }
+  }
+  LOG(INFO) << "workspace GPU bridge compositor released resource generation "
+            << generation << " slot " << slot_index << " revision "
+            << released_revision << " resource_id " << resource_id
+            << " matched " << released << " sync_has_data "
+            << sync_token.HasData() << " sync_verified "
+            << sync_token.verified_flush() << " lost_resource "
+            << lost_resource;
+}
+
+bool CefWorkspaceGpuBridgeSurfaceService::ConfigureSwapchain(
+    std::string_view surface_id,
+    std::string_view swapchain_json,
+    CefString* result_code,
+    CefString* result_detail) {
+  if (!CEF_CURRENTLY_ON_UIT()) {
+    SetResult(result_code, result_detail, "ui_thread_required",
+              "workspace GPU bridge swapchain configuration must run on the "
+              "CEF UI thread");
+    return false;
+  }
+  if (!IsWorkspaceSurfaceId(surface_id) || swapchain_json.empty()) {
+    SetResult(result_code, result_detail, "invalid_surface",
+              "workspace GPU bridge swapchain configuration requires the "
+              "workspace surface id and swapchain metadata");
+    return false;
+  }
+
+  std::string parse_code;
+  std::string parse_detail;
+  ParsedSwapchain parsed;
+  if (!ParseSwapchainJson(swapchain_json, &parsed, &parse_code,
+                          &parse_detail)) {
+    SetResult(result_code, result_detail,
+              parse_code.empty() ? "invalid_swapchain_metadata" : parse_code,
+              parse_detail);
+    LOG(WARNING) << "workspace GPU bridge swapchain configuration rejected "
+                 << surface_id << ": " << parse_code << ": "
+                 << parse_detail;
+    return false;
+  }
+
+  SwapchainState next_state;
+  next_state.generation = parsed.generation;
+  next_state.width = parsed.width;
+  next_state.height = parsed.height;
+  for (const ParsedSwapchainSlot& parsed_slot : parsed.slots) {
+    DmaBufWorkspaceSource source;
+    std::string slot_code;
+    std::string slot_detail;
+    if (!ParseDmaBufWorkspaceSource(parsed_slot.source_json, &source,
+                                    &slot_code, &slot_detail)) {
+      SetResult(result_code, result_detail,
+                slot_code.empty() ? "invalid_dmabuf_metadata" : slot_code,
+                slot_detail);
+      LOG(WARNING) << "workspace GPU bridge swapchain slot rejected "
+                   << surface_id << " slot " << parsed_slot.slot_index << ": "
+                   << slot_code << ": " << slot_detail;
+      return false;
+    }
+    if (source.width != parsed.width || source.height != parsed.height) {
+      SetResult(result_code, result_detail, "invalid_swapchain_metadata",
+                "workspace GPU bridge swapchain slot dimensions must match "
+                "the configured workspace dimensions");
+      LOG(WARNING) << "workspace GPU bridge swapchain slot dimension mismatch "
+                   << surface_id << " slot " << parsed_slot.slot_index
+                   << " slot_size " << source.width << "x" << source.height
+                   << " swapchain_size " << parsed.width << "x"
+                   << parsed.height;
+      return false;
+    }
+
+    const std::string slot_revision =
+        "slot:" + base::NumberToString(parsed_slot.slot_index);
+    std::optional<Entry> maybe_entry = CreateExportedSharedImageForDmaBuf(
+        parsed_slot.source_json, surface_id, slot_revision, &slot_code,
+        &slot_detail, /*require_webgpu_read=*/false);
+    if (!maybe_entry.has_value()) {
+      SetResult(result_code, result_detail,
+                slot_code.empty() ? "shared_image_creation_failure" : slot_code,
+                slot_detail.empty()
+                    ? "workspace GPU bridge failed to import swapchain slot"
+                    : slot_detail);
+      LOG(WARNING) << "workspace GPU bridge swapchain slot import failed "
+                   << surface_id << " slot " << parsed_slot.slot_index << ": "
+                   << slot_code << ": " << slot_detail;
+      return false;
+    }
+
+    SwapchainSlotEntry slot_entry;
+    slot_entry.entry = std::move(*maybe_entry);
+    slot_entry.slot_index = parsed_slot.slot_index;
+    slot_entry.slot_revision = parsed_slot.slot_revision;
+    slot_entry.width = source.width;
+    slot_entry.height = source.height;
+    next_state.slots.insert_or_assign(parsed_slot.slot_index,
+                                      std::move(slot_entry));
+    LOG(INFO) << "workspace GPU bridge imported persistent swapchain slot "
+              << surface_id << " slot " << parsed_slot.slot_index
+              << " generation " << parsed.generation << " size "
+              << source.width << "x" << source.height << " modifier "
+              << source.drm_modifier << " stride " << source.stride_bytes;
+  }
+  if (next_state.slots.size() != parsed.slots.size()) {
+    SetResult(result_code, result_detail, "invalid_swapchain_metadata",
+              "workspace GPU bridge swapchain slot indexes must be unique");
+    return false;
+  }
+
+  std::unique_ptr<ui::Layer> retired_layer;
+  {
+    base::AutoLock hold(lock_);
+    retired_layer = std::move(workspace_layer_);
+    RetireActiveSwapchainLocked();
+    workspace_swapchain_ = std::move(next_state);
+    workspace_swapchain_configured_ = true;
+    front_slot_present_log_count_ = 0U;
+    PruneRetiredSwapchainsLocked();
+  }
+  DestroyWorkspaceLayer(std::move(retired_layer));
+  SetResult(result_code, result_detail, "ok", "configured workspace swapchain");
+  LOG(INFO) << "workspace GPU bridge configured swapchain " << surface_id
+            << " generation " << parsed.generation << " size " << parsed.width
+            << "x" << parsed.height << " slots " << parsed.slots.size();
+  return true;
+}
