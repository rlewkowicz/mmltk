+bool CefWorkspaceGpuBridgeSurfaceService::PresentFrontSlot(
+    std::string_view surface_id,
+    uint32_t slot_index,
+    uint64_t revision,
+    uint64_t swapchain_generation,
+    int32_t bounds_x,
+    int32_t bounds_y,
+    int32_t bounds_width,
+    int32_t bounds_height,
+    int32_t damage_x,
+    int32_t damage_y,
+    int32_t damage_width,
+    int32_t damage_height,
+    uint32_t ready_sync_kind,
+    uint64_t ready_sync_handle,
+    uint64_t ready_sync_value,
+    CefString* result_code,
+    CefString* result_detail) {
+  if (!CEF_CURRENTLY_ON_UIT()) {
+    SetResult(result_code, result_detail, "ui_thread_required",
+              "workspace GPU bridge front-slot present must run on the CEF "
+              "UI thread");
+    return false;
+  }
+  if (!IsWorkspaceSurfaceId(surface_id) || revision == 0U || bounds_width <= 0 ||
+      bounds_height <= 0) {
+    SetResult(result_code, result_detail, "invalid_surface",
+              "workspace GPU bridge present requires workspace surface id, "
+              "revision, and non-empty workspace bounds");
+    return false;
+  }
+
+  const gfx::Rect bounds_rect(bounds_x, bounds_y, bounds_width, bounds_height);
+  gfx::Rect damage_rect(damage_x, damage_y, damage_width, damage_height);
+  if (damage_rect.IsEmpty()) {
+    damage_rect = bounds_rect;
+  }
+
+  scoped_refptr<gpu::ClientSharedImage> shared_image;
+  ProducerReadiness producer_readiness;
+  ui::Compositor* compositor = nullptr;
+  ui::Layer* root_layer = nullptr;
+  ui::Layer* workspace_layer = nullptr;
+  uint32_t slot_width = 0;
+  uint32_t slot_height = 0;
+  uint32_t present_resource_id = 0;
+  uint64_t present_generation = 0;
+  uint64_t present_log_count = 0;
+  {
+    base::AutoLock hold(lock_);
+    if (!workspace_swapchain_configured_) {
+      SetResult(result_code, result_detail, "swapchain_not_configured",
+                "workspace GPU bridge present requires a configured "
+                "swapchain");
+      return false;
+    }
+    SwapchainState& state = workspace_swapchain_;
+    if (swapchain_generation != 0U && swapchain_generation != state.generation) {
+      SetResult(result_code, result_detail, "stale_swapchain_generation",
+                "workspace GPU bridge present generation does not match the "
+                "configured swapchain");
+      return false;
+    }
+    const auto slot_it = state.slots.find(slot_index);
+    if (slot_it == state.slots.end()) {
+      SetResult(result_code, result_detail, "invalid_swapchain_slot",
+                "workspace GPU bridge present referenced an unknown "
+                "swapchain slot");
+      return false;
+    }
+    if (slot_it->second.display_read_pending) {
+      SetResult(result_code, result_detail, "slot_display_busy",
+                "workspace GPU bridge present slot is still held by the "
+                "compositor");
+      LOG(WARNING) << "workspace GPU bridge front slot busy " << surface_id
+                   << " slot " << slot_index << " generation "
+                   << state.generation << " outstanding_resource_id "
+                   << slot_it->second.outstanding_resource_id
+                   << " outstanding_revision "
+                   << slot_it->second.outstanding_revision;
+      return false;
+    }
+    shared_image = slot_it->second.entry.shared_image;
+    producer_readiness = slot_it->second.entry.producer_readiness;
+    slot_width = slot_it->second.width;
+    slot_height = slot_it->second.height;
+    present_generation = state.generation;
+    compositor = compositor_;
+    root_layer = compositor_root_layer_;
+    present_log_count = ++front_slot_present_log_count_;
+  }
+
+  auto* transport_factory = content::ImageTransportFactory::GetInstance();
+  auto* context_factory =
+      transport_factory ? transport_factory->GetContextFactory() : nullptr;
+  scoped_refptr<viz::RasterContextProvider> context_provider =
+      context_factory ? context_factory->SharedMainThreadRasterContextProvider()
+                      : nullptr;
+  gpu::SharedImageInterface* shared_image_interface =
+      context_provider ? context_provider->SharedImageInterface() : nullptr;
+  if (!shared_image || !shared_image_interface) {
+    SetResult(result_code, result_detail, "shared_image_creation_failure",
+              "workspace GPU bridge present has no SharedImage interface");
+    return false;
+  }
+
+  std::string readiness_code;
+  std::string readiness_detail;
+  if (!ValidateProducerReadiness(producer_readiness, ready_sync_kind,
+                                 ready_sync_handle, ready_sync_value,
+                                 &readiness_code, &readiness_detail)) {
+    SetResult(result_code, result_detail, readiness_code, readiness_detail);
+    return false;
+  }
+
+  std::unique_ptr<gfx::GpuFence> acquire_fence = MakeProducerAcquireFence(
+      ready_sync_kind, ready_sync_handle, &readiness_code, &readiness_detail);
+  if (!readiness_code.empty()) {
+    SetResult(result_code, result_detail, readiness_code, readiness_detail);
+    return false;
+  }
+
+  gpu::SyncToken producer_update_sync_token =
+      NotifyExternalProducerUpdate(shared_image, shared_image_interface,
+                                   std::move(acquire_fence));
+
+  const gfx::Size texture_size(bounds_rect.width(), bounds_rect.height());
+  {
+    base::AutoLock hold(lock_);
+    if (!workspace_swapchain_configured_ ||
+        workspace_swapchain_.generation != present_generation) {
+      SetResult(result_code, result_detail, "stale_swapchain_generation",
+                "workspace GPU bridge present generation was replaced before "
+                "the compositor resource was submitted");
+      return false;
+    }
+    auto slot_it = workspace_swapchain_.slots.find(slot_index);
+    if (slot_it == workspace_swapchain_.slots.end()) {
+      SetResult(result_code, result_detail, "invalid_swapchain_slot",
+                "workspace GPU bridge present slot was removed before the "
+                "compositor resource was submitted");
+      return false;
+    }
+    if (slot_it->second.display_read_pending) {
+      SetResult(result_code, result_detail, "slot_display_busy",
+                "workspace GPU bridge present slot became busy before the "
+                "compositor resource was submitted");
+      LOG(WARNING) << "workspace GPU bridge front slot busy before submit "
+                   << surface_id << " slot " << slot_index << " generation "
+                   << workspace_swapchain_.generation
+                   << " outstanding_resource_id "
+                   << slot_it->second.outstanding_resource_id
+                   << " outstanding_revision "
+                   << slot_it->second.outstanding_revision;
+      return false;
+    }
+    present_resource_id = NextWorkspaceTransferableResourceId();
+    slot_it->second.display_read_pending = true;
+    slot_it->second.outstanding_resource_id = present_resource_id;
+    slot_it->second.outstanding_revision = revision;
+    workspace_swapchain_.front_slot_index = slot_index;
+    workspace_swapchain_.front_revision = revision;
+    if (!workspace_layer_) {
+      workspace_layer_ = std::make_unique<ui::Layer>(ui::LAYER_TEXTURED);
+      workspace_layer_->SetName("mmltk workspace native swapchain");
+      workspace_layer_->SetFillsBoundsOpaquely(true);
+      workspace_layer_->SetFillsBoundsCompletely(true);
+    }
+    workspace_layer = workspace_layer_.get();
+  }
+  if (workspace_layer) {
+    if (root_layer && workspace_layer->parent() != root_layer) {
+      if (ui::Layer* parent = workspace_layer->parent()) {
+        parent->Remove(workspace_layer);
+      }
+      root_layer->Add(workspace_layer);
+    }
+    workspace_layer->SetVisible(root_layer != nullptr);
+    workspace_layer->SetBounds(bounds_rect);
+    viz::TransferableResource resource = viz::TransferableResource::Make(
+        shared_image, viz::TransferableResource::ResourceSource::kUI,
+        producer_update_sync_token);
+    resource.id = viz::ResourceId(present_resource_id);
+    resource.synchronization_type =
+        viz::TransferableResource::SynchronizationType::kSyncToken;
+    workspace_layer->SetTransferableResource(
+        resource,
+        base::BindOnce(
+            &CefWorkspaceGpuBridgeSurfaceService::
+                OnWorkspaceTransferableResourceReleased,
+            base::Unretained(this), present_generation, slot_index,
+            present_resource_id),
+        texture_size);
+    gfx::Rect layer_damage = damage_rect;
+    layer_damage.Offset(-bounds_rect.x(), -bounds_rect.y());
+    workspace_layer->SchedulePaint(layer_damage.IsEmpty()
+                                       ? gfx::Rect(texture_size)
+                                       : layer_damage);
+  }
+  if (compositor) {
+    compositor->ScheduleRedrawRect(damage_rect);
+  }
+
+  if (ShouldLogCadence(present_log_count)) {
+    LOG(INFO) << "workspace GPU bridge presented front slot " << surface_id
+              << " slot " << slot_index << " revision " << revision
+              << " generation " << present_generation << " bounds "
+              << bounds_rect.ToString() << " damage " << damage_rect.ToString()
+              << " compositor_bound " << static_cast<bool>(compositor)
+              << " root_layer_bound " << static_cast<bool>(root_layer)
+              << " sync_has_data " << producer_update_sync_token.HasData()
+              << " sync_verified "
+              << producer_update_sync_token.verified_flush()
+              << " resource_id " << present_resource_id
+              << " ready_sync_kind " << ready_sync_kind
+              << " ready_sync_handle " << ready_sync_handle
+              << " ready_sync_value " << ready_sync_value << " slot_size "
+              << slot_width << "x" << slot_height;
+  }
+  SetResult(result_code, result_detail, "ok", "presented workspace front slot");
+  return true;
+}
+
+bool CefWorkspaceGpuBridgeSurfaceService::DestroySwapchain(
+    std::string_view surface_id,
+    CefString* result_code,
+    CefString* result_detail) {
+  if (!CEF_CURRENTLY_ON_UIT()) {
+    SetResult(result_code, result_detail, "ui_thread_required",
+              "workspace GPU bridge swapchain destruction must run on the "
+              "CEF UI thread");
+    return false;
+  }
+  if (!IsWorkspaceSurfaceId(surface_id)) {
+    SetResult(result_code, result_detail, "invalid_surface",
+              "workspace GPU bridge destroy requires the workspace surface id");
+    return false;
+  }
+  bool erased = false;
+  std::unique_ptr<ui::Layer> detached_layer;
+  {
+    base::AutoLock hold(lock_);
+    erased = workspace_swapchain_configured_ ||
+             !workspace_swapchain_.slots.empty();
+    detached_layer = std::move(workspace_layer_);
+    RetireActiveSwapchainLocked();
+    PruneRetiredSwapchainsLocked();
+  }
+  DestroyWorkspaceLayer(std::move(detached_layer));
+  SetResult(result_code, result_detail, "ok", "destroyed workspace swapchain");
+  LOG(INFO) << "workspace GPU bridge destroyed swapchain " << surface_id
+            << " existed " << erased;
+  return true;
+}
+
+void CefWorkspaceGpuBridgeSurfaceService::BindCompositor(
+    int browser_id,
+    ui::Compositor* compositor,
+    ui::Layer* root_layer) {
+  CEF_REQUIRE_UIT_RETURN_VOID();
+  base::AutoLock hold(lock_);
+  compositor_browser_id_ = browser_id;
+  compositor_ = compositor;
+  compositor_root_layer_ = root_layer;
+  if (workspace_layer_ && root_layer && workspace_layer_->parent() != root_layer) {
+    if (ui::Layer* parent = workspace_layer_->parent()) {
+      parent->Remove(workspace_layer_.get());
+    }
+    root_layer->Add(workspace_layer_.get());
+  }
+  LOG(INFO) << "workspace GPU bridge bound compositor browser " << browser_id
+            << " compositor " << compositor << " root_layer " << root_layer;
+}
+
+void CefWorkspaceGpuBridgeSurfaceService::ClearCompositorBinding(
+    int browser_id) {
+  CEF_REQUIRE_UIT_RETURN_VOID();
+  bool retired_swapchain = false;
+  std::unique_ptr<ui::Layer> detached_layer;
+  {
+    base::AutoLock hold(lock_);
+    if (compositor_browser_id_ != browser_id) {
+      return;
+    }
+    retired_swapchain = workspace_swapchain_configured_ ||
+                        !workspace_swapchain_.slots.empty();
+    detached_layer = std::move(workspace_layer_);
+    RetireActiveSwapchainLocked();
+    PruneRetiredSwapchainsLocked();
+    compositor_ = nullptr;
+    compositor_root_layer_ = nullptr;
+    compositor_browser_id_ = 0;
+  }
+  DestroyWorkspaceLayer(std::move(detached_layer));
+  LOG(INFO) << "workspace GPU bridge cleared compositor binding browser "
+            << browser_id << " retired_swapchain " << retired_swapchain;
+}
