+uint32_t NextWorkspaceTransferableResourceId() {
+  constexpr uint32_t kFirstResourceId = 1U;
+  const uint32_t reserved_start = viz::kVizReservedRangeStartId.GetUnsafeValue();
+  static std::atomic<uint32_t> next_id{kFirstResourceId};
+  for (;;) {
+    uint32_t id = next_id.load(std::memory_order_relaxed);
+    if (id == 0U || id >= reserved_start) {
+      next_id.compare_exchange_weak(id, kFirstResourceId,
+                                    std::memory_order_relaxed,
+                                    std::memory_order_relaxed);
+      continue;
+    }
+    uint32_t next = id + 1U;
+    if (next == 0U || next >= reserved_start) {
+      next = kFirstResourceId;
+    }
+    if (next_id.compare_exchange_weak(id, next, std::memory_order_relaxed,
+                                      std::memory_order_relaxed)) {
+      return id;
+    }
+  }
+}
+
+bool SwapchainHasPendingDisplayReads(
+    const CefWorkspaceGpuBridgeSurfaceService::SwapchainState& state) {
+  for (const auto& slot_pair : state.slots) {
+    if (slot_pair.second.display_read_pending) {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool ClearPendingSwapchainResource(
+    CefWorkspaceGpuBridgeSurfaceService::SwapchainState* state,
+    uint64_t generation,
+    uint32_t slot_index,
+    uint32_t resource_id,
+    uint64_t* released_revision) {
+  if (!state || state->generation != generation) {
+    return false;
+  }
+  auto slot_it = state->slots.find(slot_index);
+  if (slot_it == state->slots.end() ||
+      !slot_it->second.display_read_pending ||
+      slot_it->second.outstanding_resource_id != resource_id) {
+    return false;
+  }
+  if (released_revision) {
+    *released_revision = slot_it->second.outstanding_revision;
+  }
+  slot_it->second.display_read_pending = false;
+  slot_it->second.outstanding_resource_id = 0U;
+  slot_it->second.outstanding_revision = 0U;
+  return true;
+}
+
+bool ValidateProducerReadiness(
+    const CefWorkspaceGpuBridgeSurfaceService::ProducerReadiness& configured,
+    uint32_t ready_sync_kind,
+    uint64_t ready_sync_handle,
+    uint64_t ready_sync_value,
+    std::string* result_code,
+    std::string* result_detail) {
+  constexpr uint32_t kSyncKindCudaEvent = 1U;
+  constexpr uint32_t kSyncKindNativeFenceFd = 3U;
+  if ((ready_sync_kind != kSyncKindCudaEvent &&
+       ready_sync_kind != kSyncKindNativeFenceFd) ||
+      ready_sync_handle == 0U) {
+    SetResult(result_code, result_detail, "missing_sync_metadata",
+              "workspace GPU bridge present requires CUDA ready metadata or "
+              "a native acquire fence for the front swapchain slot");
+    return false;
+  }
+  if (ready_sync_kind != kSyncKindNativeFenceFd &&
+      configured.ready_sync_kind != 0U &&
+      (configured.ready_sync_kind != ready_sync_kind ||
+       configured.ready_sync_handle != ready_sync_handle)) {
+    SetResult(result_code, result_detail, "stale_ready_sync",
+              "workspace GPU bridge present readiness does not match the "
+              "configured swapchain slot");
+    return false;
+  }
+  (void)ready_sync_value;
+  return true;
+}
+
+std::unique_ptr<gfx::GpuFence> MakeProducerAcquireFence(
+    uint32_t ready_sync_kind,
+    uint64_t ready_sync_handle,
+    std::string* result_code,
+    std::string* result_detail) {
+  constexpr uint32_t kSyncKindNativeFenceFd = 3U;
+  if (ready_sync_kind != kSyncKindNativeFenceFd) {
+    return nullptr;
+  }
+  if (ready_sync_handle == 0U ||
+      ready_sync_handle >
+          static_cast<uint64_t>(std::numeric_limits<int>::max())) {
+    SetResult(result_code, result_detail, "invalid_sync_metadata",
+              "workspace GPU bridge present carried an invalid native fence fd");
+    return nullptr;
+  }
+  const int duplicated_fd =
+      ::fcntl(static_cast<int>(ready_sync_handle), F_DUPFD_CLOEXEC, 3);
+  if (duplicated_fd < 0) {
+    SetResult(result_code, result_detail, "invalid_sync_metadata",
+              "workspace GPU bridge present could not duplicate the native "
+              "acquire fence fd");
+    return nullptr;
+  }
+  gfx::GpuFenceHandle fence_handle;
+  fence_handle.Adopt(base::ScopedFD(duplicated_fd));
+  return std::make_unique<gfx::GpuFence>(std::move(fence_handle));
+}
+
+gpu::SyncToken NotifyExternalProducerUpdate(
+    scoped_refptr<gpu::ClientSharedImage> shared_image,
+    gpu::SharedImageInterface* shared_image_interface,
+    std::unique_ptr<gfx::GpuFence> acquire_fence) {
+  gpu::SyncToken producer_update_sync_token;
+  if (acquire_fence) {
+    shared_image_interface->UpdateSharedImage(
+        gpu::SyncToken(), std::move(acquire_fence), shared_image->mailbox());
+    producer_update_sync_token = shared_image_interface->GenUnverifiedSyncToken();
+  } else {
+    producer_update_sync_token = shared_image->BackingWasExternallyUpdated(
+        shared_image->creation_sync_token());
+  }
+  if (producer_update_sync_token.HasData()) {
+    shared_image_interface->VerifySyncToken(producer_update_sync_token);
+  }
+  return producer_update_sync_token;
+}
