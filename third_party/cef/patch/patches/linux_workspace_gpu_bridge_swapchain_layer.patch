+struct ParsedSwapchainSlot {
+  uint32_t slot_index = 0;
+  uint64_t slot_revision = 0;
+  std::string source_json;
+};
+
+struct ParsedSwapchain {
+  uint64_t generation = 0;
+  uint32_t width = 0;
+  uint32_t height = 0;
+  std::vector<ParsedSwapchainSlot> slots;
+};
+
+bool ParseSwapchainJson(std::string_view swapchain_json,
+                        ParsedSwapchain* swapchain,
+                        std::string* result_code,
+                        std::string* result_detail) {
+  std::optional<base::Value> parsed =
+      base::JSONReader::Read(swapchain_json,
+                             base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+  if (!parsed || !parsed->is_dict()) {
+    SetResult(result_code, result_detail, "invalid_swapchain_metadata",
+              "workspace GPU bridge swapchain JSON must be an object");
+    return false;
+  }
+  const base::DictValue& root = parsed->GetDict();
+  const std::optional<uint32_t> width =
+      root.Find("width") ? ParseUint32(*root.Find("width")) : std::nullopt;
+  const std::optional<uint32_t> height =
+      root.Find("height") ? ParseUint32(*root.Find("height")) : std::nullopt;
+  const std::optional<uint64_t> generation =
+      root.Find("generation") ? ParseUint64(*root.Find("generation"))
+                              : std::nullopt;
+  const base::ListValue* slots = root.FindList("slots");
+  if (!width.has_value() || !height.has_value() || *width == 0U ||
+      *height == 0U || !generation.has_value() || !slots || slots->empty()) {
+    SetResult(result_code, result_detail, "invalid_swapchain_metadata",
+              "workspace GPU bridge swapchain requires width, height, "
+              "generation, and at least one slot");
+    return false;
+  }
+
+  ParsedSwapchain next;
+  next.generation = *generation;
+  next.width = *width;
+  next.height = *height;
+  next.slots.reserve(slots->size());
+  for (const base::Value& slot_value : *slots) {
+    if (!slot_value.is_dict()) {
+      SetResult(result_code, result_detail, "invalid_swapchain_metadata",
+                "workspace GPU bridge swapchain slot must be an object");
+      return false;
+    }
+    const base::DictValue& slot = slot_value.GetDict();
+    const std::optional<uint32_t> slot_index =
+        slot.Find("slot_index") ? ParseUint32(*slot.Find("slot_index"))
+                                : std::nullopt;
+    const std::optional<uint64_t> slot_revision =
+        slot.Find("revision") ? ParseUint64(*slot.Find("revision"))
+                              : std::optional<uint64_t>(0U);
+    if (!slot_index.has_value() || !slot_revision.has_value()) {
+      SetResult(result_code, result_detail, "invalid_swapchain_metadata",
+                "workspace GPU bridge swapchain slot requires slot_index");
+      return false;
+    }
+    std::string source_json;
+    if (!base::JSONWriter::Write(slot_value, &source_json) ||
+        source_json.empty()) {
+      SetResult(result_code, result_detail, "invalid_swapchain_metadata",
+                "workspace GPU bridge could not serialize swapchain slot "
+                "metadata");
+      return false;
+    }
+    next.slots.push_back(
+        ParsedSwapchainSlot{*slot_index, *slot_revision, source_json});
+  }
+
+  *swapchain = std::move(next);
+  return true;
+}
