+std::optional<uint32_t> ParseUint32(const base::Value& value) {
+  if (const auto int_value = value.GetIfInt()) {
+    if (*int_value >= 0) {
+      return static_cast<uint32_t>(*int_value);
+    }
+  }
+  if (const auto double_value = value.GetIfDouble()) {
+    if (*double_value >= 0.0 &&
+        *double_value <= std::numeric_limits<uint32_t>::max() &&
+        std::floor(*double_value) == *double_value) {
+      return static_cast<uint32_t>(*double_value);
+    }
+  }
+  if (const std::string* string_value = value.GetIfString()) {
+    uint32_t parsed = 0;
+    if (base::StringToUint(*string_value, &parsed)) {
+      return parsed;
+    }
+  }
+  return std::nullopt;
+}
+
+std::optional<std::string> ParseString(const base::Value& value) {
+  if (const std::string* string_value = value.GetIfString()) {
+    return *string_value;
+  }
+  return std::nullopt;
+}
+
+std::optional<viz::SharedImageFormat> ParseSharedImageFormat(
+    const base::Value& value) {
+  std::optional<std::string> format_name = ParseString(value);
+  if (!format_name.has_value() && value.is_dict()) {
+    const base::DictValue& dict = value.GetDict();
+    for (std::string_view key :
+         {"single_plane", "single_plane_format", "format", "name"}) {
+      if (const std::string* nested_name = dict.FindString(key)) {
+        format_name = *nested_name;
+        break;
+      }
+    }
+  }
+  if (!format_name.has_value()) {
+    return std::nullopt;
+  }
+
+  const std::string canonical_name = base::ToUpperASCII(*format_name);
+  if (canonical_name == "RGBA_8888" || canonical_name == "RGBA8UNORM") {
+    return viz::SinglePlaneFormat::kRGBA_8888;
+  }
+  if (canonical_name == "BGRA_8888") {
+    return std::nullopt;
+  }
+  if (canonical_name == "RGBA_F16") {
+    return std::nullopt;
+  }
+  return std::nullopt;
+}
+
+std::optional<gpu::Mailbox> ParseMailbox(const base::DictValue& dict) {
+  const base::DictValue* mailbox_dict = dict.FindDict("mailbox");
+  if (!mailbox_dict) {
+    return std::nullopt;
+  }
+  const base::ListValue* mailbox_name = mailbox_dict->FindList("name");
+  if (!mailbox_name || mailbox_name->size() != GL_MAILBOX_SIZE_CHROMIUM) {
+    return std::nullopt;
+  }
+
+  int8_t mailbox_bytes[GL_MAILBOX_SIZE_CHROMIUM];
+  for (size_t index = 0; index < mailbox_name->size(); ++index) {
+    const std::optional<uint32_t> byte_value = ParseUint32((*mailbox_name)[index]);
+    if (!byte_value.has_value() || *byte_value > 255U) {
+      return std::nullopt;
+    }
+    mailbox_bytes[index] = static_cast<int8_t>(*byte_value);
+  }
+
+  gpu::Mailbox mailbox;
+  mailbox.SetName(mailbox_bytes);
+  return mailbox;
+}
+
+std::optional<gfx::Size> ParseSharedImageSize(const base::DictValue& metadata) {
+  const base::DictValue* size_dict = metadata.FindDict("size");
+  if (!size_dict) {
+    return std::nullopt;
+  }
+  const std::optional<uint32_t> width =
+      size_dict->Find("width") ? ParseUint32(*size_dict->Find("width"))
+                               : std::nullopt;
+  const std::optional<uint32_t> height =
+      size_dict->Find("height") ? ParseUint32(*size_dict->Find("height"))
+                                : std::nullopt;
+  if (!width.has_value() || !height.has_value() || *width == 0U ||
+      *height == 0U) {
+    return std::nullopt;
+  }
+  return gfx::Size(base::checked_cast<int>(*width),
+                   base::checked_cast<int>(*height));
+}
