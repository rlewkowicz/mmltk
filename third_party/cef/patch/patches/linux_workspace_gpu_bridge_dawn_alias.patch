+// Copyright 2026 The Chromium Embedded Framework Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "cef/libcef/renderer/workspace_gpu_bridge_texture_importer.h"
+
+#include "cef/libcef/common/workspace_gpu_bridge_export.h"
+#include "cef/libcef/renderer/workspace_gpu_bridge.h"
+
+#include "include/wrapper/cef_helpers.h"
+
+bool ImportWorkspaceGpuBridgeTexture(
+    CefRefPtr<CefV8Value> device,
+    std::string_view surface_id,
+    std::string_view revision,
+    std::string_view exported_shared_image_json,
+    CefRefPtr<CefV8Value>* texture_out,
+    CefString* exception) {
+  CEF_REQUIRE_RENDERER_THREAD();
+  if (surface_id != "workspace" || revision.empty()) {
+    if (exception) {
+      *exception =
+          "workspace GPU bridge importTexture requires the workspace surface "
+          "id and revision";
+    }
+    return false;
+  }
+  if (exported_shared_image_json.empty()) {
+    if (exception) {
+      *exception =
+          "workspace GPU bridge importTexture requires an exported "
+          "SharedImage payload";
+    }
+    return false;
+  }
+
+  CefRefPtr<CefV8Context> context = CefV8Context::GetCurrentContext();
+  if (!context || !context->IsValid()) {
+    if (exception) {
+      *exception = "workspace GPU bridge has no valid renderer context";
+    }
+    return false;
+  }
+
+  return workspace_gpu_bridge::ImportTexture(
+      context->GetFrame(), std::move(device), std::string(surface_id),
+      std::string(revision), exported_shared_image_json, texture_out, exception);
+}
+
+extern "C" bool
+mmltk_cef_workspace_gpu_bridge_renderer_helper_present() noexcept {
+  return true;
+}
+
+extern "C" bool mmltk_cef_workspace_gpu_bridge_import_texture(
+    CefRefPtr<CefV8Value> device,
+    const char* surface_id,
+    size_t surface_id_length,
+    const char* revision,
+    size_t revision_length,
+    const char* exported_shared_image_json,
+    size_t exported_shared_image_json_length,
+    CefRefPtr<CefV8Value>* texture_out,
+    CefString* exception) noexcept {
+  if (!surface_id || surface_id_length == 0U || !revision ||
+      revision_length == 0U) {
+    if (exception) {
+      *exception =
+          "workspace GPU bridge importTexture requires a surface id and revision";
+    }
+    return false;
+  }
+  if (!exported_shared_image_json || exported_shared_image_json_length == 0U) {
+    if (exception) {
+      *exception =
+          "workspace GPU bridge importTexture requires an exported "
+          "SharedImage payload";
+    }
+    return false;
+  }
+  return ImportWorkspaceGpuBridgeTexture(
+      std::move(device), std::string_view(surface_id, surface_id_length),
+      std::string_view(revision, revision_length),
+      std::string_view(exported_shared_image_json,
+                       exported_shared_image_json_length),
+      texture_out, exception);
+}
