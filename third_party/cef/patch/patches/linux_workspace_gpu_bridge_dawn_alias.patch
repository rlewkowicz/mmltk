+v8::MaybeLocal<v8::Value> ImportWorkspaceGpuBridgeTexture(
+    v8::Local<v8::Context> context,
+    v8::Local<v8::Object> device,
+    const std::string& exported_shared_image_json,
+    v8::TryCatch& try_catch,
+    v8::Isolate* isolate,
+    blink::GPUTexture** imported_texture_out) {
+  (void)try_catch;
+  if (imported_texture_out) {
+    *imported_texture_out = nullptr;
+  }
+
+  std::optional<base::Value> parsed =
+      base::JSONReader::Read(exported_shared_image_json,
+                             base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+  if (!parsed || !parsed->is_dict()) {
+    return {};
+  }
+
+  auto* blink_device = blink::V8GPUDevice::ToWrappableUnsafe(isolate, device);
+  if (!blink_device) {
+    return {};
+  }
+
+  const base::DictValue& exported = parsed->GetDict();
+  const base::DictValue* metadata = exported.FindDict("metadata");
+  const std::optional<gpu::Mailbox> mailbox = ParseMailbox(exported);
+  if (!metadata || !mailbox.has_value()) {
+    return {};
+  }
+
+  const std::optional<viz::SharedImageFormat> format =
+      metadata->Find("format") ? ParseSharedImageFormat(*metadata->Find("format"))
+                               : std::nullopt;
+  const std::optional<gfx::Size> size = ParseSharedImageSize(*metadata);
+  const std::optional<uint32_t> usage =
+      metadata->Find("usage") ? ParseUint32(*metadata->Find("usage"))
+                              : std::nullopt;
+  const std::optional<uint32_t> texture_target =
+      exported.Find("texture_target")
+          ? ParseUint32(*exported.Find("texture_target"))
+          : std::nullopt;
+  const bool is_software =
+      exported.Find("is_software")
+          ? exported.Find("is_software")->GetIfBool().value_or(false)
+          : false;
+  constexpr uint32_t kRequiredUsage =
+      static_cast<uint32_t>(gpu::SHARED_IMAGE_USAGE_WEBGPU_READ);
+  if (!format.has_value() || *format != viz::SinglePlaneFormat::kRGBA_8888 ||
+      !size.has_value() || !usage.has_value() ||
+      (*usage & kRequiredUsage) == 0U || !texture_target.has_value() ||
+      *texture_target == 0U || is_software) {
+    return {};
+  }
+
+  // A raw mailbox plus metadata is not enough to safely construct a
+  // production ClientSharedImage. Import must fail until the browser-side
+  // bridge exports an owned GPU ClientSharedImage payload.
+  return {};
+}
